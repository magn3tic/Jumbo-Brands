{% comment %}
  Renders freeshipping bar
{% endcomment %}
{%- if settings.enable_free_shipping and settings.order_amount_freeshipping != blank or settings.order_amount_freegift != blank -%}
  {% liquid
    assign cart_total = cart.total_price | divided_by: 100.00

    assign freeshipping_thresholds = settings.order_amount_freeshipping | newline_to_br | strip_newlines | split: '<br />'
    if settings.order_amount_freeshipping contains ';'
      assign freeshipping_thresholds = settings.order_amount_freeshipping | remove: " " | split: ';'
    endif
    assign freeshipping_threshold = false
    for threshold in freeshipping_thresholds
      unless threshold contains ':' 
        if threshold != blank 
          assign check_currency = threshold | remove: "0" | remove: "1" | remove: "2" | remove: "3" | remove: "4" | remove: "5" | remove: "6" | remove: "7" | remove : "8" | remove: "9" | remove: ":" | remove: " "
          if check_currency == '' or check_currency == '.'
            assign freeshipping_threshold_all = threshold | strip | plus: 0
          endif
        endif
      else 
        assign check_currency_first = threshold | split: ":" | first 
        assign check_currency_last = threshold | split: ":" | last 
        assign check_currency = threshold | remove_first: check_currency_first | remove: check_currency_last
        if check_currency == ':'
          if check_currency_first == cart.currency.iso_code
            assign freeshipping_threshold_currency = check_currency_last | strip | plus: 0
          endif 
        else
          assign check_currency_country = check_currency | remove: ":"
          if check_currency_first == localization.country.iso_code and check_currency_country == cart.currency.iso_code
            assign freeshipping_threshold_country = check_currency_last | strip | plus: 0
          endif
        endif 
      endunless
    endfor
    if freeshipping_threshold_all
      assign freeshipping_threshold = freeshipping_threshold_all
    endif 
    if freeshipping_threshold_currency
      assign freeshipping_threshold = freeshipping_threshold_currency
    endif 
    if freeshipping_threshold_country
      assign freeshipping_threshold = freeshipping_threshold_country
    endif 

    assign freegift_thresholds = settings.order_amount_freegift | newline_to_br | strip_newlines | split: '<br />'
    if settings.order_amount_freegift contains ';'
      assign freegift_thresholds = settings.order_amount_freegift | remove: " " | split: ';'
    endif
    assign freegift_threshold = false
    for threshold in freegift_thresholds
      unless threshold contains ':' 
        if threshold != blank 
          assign check_currency = threshold | remove: "0" | remove: "1" | remove: "2" | remove: "3" | remove: "4" | remove: "5" | remove: "6" | remove: "7" | remove : "8" | remove: "9" | remove: ":" | remove: " "
          if check_currency == '' or check_currency == '.'
            assign freegift_threshold_all = threshold | strip | plus: 0
          endif
        endif
      else 
        assign check_currency_first = threshold | split: ":" | first 
        assign check_currency_last = threshold | split: ":" | last 
        assign check_currency = threshold | remove_first: check_currency_first | remove: check_currency_last
        if check_currency == ':'
          if check_currency_first == cart.currency.iso_code
            assign freegift_threshold_currency = check_currency_last | strip | plus: 0
          endif 
        else
          assign check_currency_country = check_currency | remove: ":"
          if check_currency_first == localization.country.iso_code and check_currency_country == cart.currency.iso_code
            assign freegift_threshold_country = check_currency_last | strip | plus: 0
          endif
        endif 
      endunless
    endfor
    if freegift_threshold_all
      assign freegift_threshold = freegift_threshold_all
    endif 
    if freegift_threshold_currency
      assign freegift_threshold = freegift_threshold_currency
    endif 
    if freegift_threshold_country
      assign freegift_threshold = freegift_threshold_country
    endif 
  %}
  {% if cart.item_count > 0 %}
    {% liquid
      if freeshipping_threshold or freegift_threshold
        assign amount_to_freeshipping = freeshipping_threshold | minus: cart_total
        assign amount_to_freegift = freegift_threshold | minus: cart_total
        assign underline_width = 0
        assign freeshipping_percent = cart_total | divided_by: freeshipping_threshold
        if freeshipping_percent < 1 and amount_to_freeshipping >= amount_to_freegift
          assign underline_width = freeshipping_percent | times: 100
        elsif freeshipping_percent > 1 and settings.order_amount_freegift == blank
          assign underline_width = 100
        endif
        assign freegift_percent = cart_total | divided_by: freegift_threshold
        if freegift_percent < 1 and amount_to_freegift >= amount_to_freeshipping
          assign underline_width = freegift_percent | times: 100
        elsif freegift_percent > 1 and settings.order_amount_freeshipping == blank
          assign underline_width = 100
        endif
        if freegift_percent > 1 and freeshipping_percent > 1
          assign underline_width = 100
        endif
      endif
    %}
    {% style %}
      .free-offer-bar {
        width: 0;
      }
      .free-offer-bar.active {
        transition: width 1s ease-in-out;
        width: {{ underline_width }}%;
      }
      .icon-shipping-position {
        {% if freeshipping_threshold >= freegift_threshold or settings.order_amount_freegift == blank -%}
          left: 100%;
        {%- else -%}
          left: {{ freeshipping_threshold | times: 100 | divided_by: freegift_threshold }}%;
        {%- endif %}
      }
      .icon-offer-position {
        {% if freegift_threshold >= freeshipping_threshold or settings.order_amount_freeshipping == blank -%}
          left: 100%;
        {%- else -%}
          left: {{ freegift_threshold | times: 100 | divided_by: freeshipping_threshold }}%;
        {%- endif %}
      }
      [dir="rtl"] .icon-shipping-position {
        {% if freeshipping_threshold >= freegift_threshold or settings.order_amount_freegift == blank -%}
          right: 100%;
        {%- else -%}
          right: {{ freeshipping_threshold | times: 100 | divided_by: freegift_threshold }}%;
        {%- endif %}
      }
      [dir="rtl"] .icon-offer-position {
        {% if freegift_threshold >= freeshipping_threshold or settings.order_amount_freeshipping == blank -%}
          right: 100%;
        {%- else -%}
          right: {{ freegift_threshold | times: 100 | divided_by: freeshipping_threshold }}%;
        {%- endif %}
      }
    {% endstyle %}
    {% if freeshipping_threshold or freegift_threshold %}
      <div x-data="{ active: false }" x-intersect:enter.once="active = true">
        <div class="{% if main_cart %}lg:w-1/3 {% endif %}bg-[rgba(var(--color-success),0.1)]{% if freeshipping_threshold and freegift_threshold %} pt-3 pb-7 pl-4 pr-8 rtl:pr-4 rtl:pl-8{% else %} pt-3 pb-3 pl-4 pr-4{% endif %}{% if settings.edges_type == 'rounded_corners' %} rounded-lg{% endif %}{% if main_cart %} mb-8{% else %} mb-2.5 lg:mb-4.5{% endif %}">
          {% if amount_to_freeshipping > 0 or amount_to_freegift > 0 %}
            <div class="flex flex-col justify-center gap-2">
              {% if settings.order_amount_freeshipping != blank and freeshipping_threshold %}
                <div class="flex items-center gap-2">
                  <div class="w-5 h-5 shrink-0">
                    {% render 'icon-labels-bags', icon: 'delivery-truck' %}
                  </div>
                  {% if amount_to_freeshipping > 0 %}
                    {% assign amount_to_freeshipping_money = amount_to_freeshipping | times: 100 | money %}
                    <span>{{ 'general.cart.enable_amount_freeship_html' | t: amount_to_freeshipping: amount_to_freeshipping_money }}</span>
                  {% else %}
                    <span>{{ 'general.cart.freeshipping' | t }}</span>
                  {% endif %}
                </div>
              {% endif %}
              {% if settings.order_amount_freegift != blank and freegift_threshold %}
                <div class="flex items-center gap-2">
                  <div class="w-5 h-5 relative shrink-0">
                    {% if settings.custom_image_icon_other_offer != blank %}
                      {% # theme-check-disable ImgLazyLoading %}
                      <img
                        src="{{ settings.custom_image_icon_other_offer | image_url: width: 20 }}"
                        alt="{{ settings.custom_image_icon_other_offer.alt | escape }}"
                        {% if settings.enable_lazy_loading_image %}loading="lazy"{% else %}loading="eager"{% endif %}
                        onload="this.closest('.skeleton-image')?.classList.remove('animate-Xpulse', 'skeleton-image');"
                        width="{{ settings.custom_image_icon_other_offer.width }}"
                        height="{{ settings.custom_image_icon_other_offer.height }}"
                        style="object-position: {{ settings.custom_image_icon_other_offer.presentation.focal_point }}"
                        class="object-cover absolute top-0 left-0 w-full h-full{% if settings.custom_image_icon_other_offer != blank %} animate-Xpulse skeleton-image{% endif %}"
                      >
                      {% # theme-check-enable ImgLazyLoading %}
                    {% else %}
                      {% if settings.custom_icon_other_offer == blank %}
                        {% if settings.another_icon_other_offer != blank and settings.icon_other_offer == 'another_icon' %}
                          {% render 'icon-new-alls', icon: settings.another_icon_other_offer %}
                        {% else %}
                          {% render 'icon-labels-bags', icon: settings.icon_other_offer %}
                        {% endif %}
                      {% else %}
                        {{ settings.custom_icon_other_offer }}
                      {% endif %}
                    {% endif %}
                  </div>
                  {% if amount_to_freegift > 0 %}
                    {% assign amount_to_freegift_money = amount_to_freegift | times: 100 | money %}
                    <span>{{ 'general.cart.enable_amount_freegift_html' | t: amount_to_freegift: amount_to_freegift_money, other_offer: settings.other_offer_name }}</span>
                  {% else %}
                    <span>{{ 'general.cart.freegift' | t: other_offer: settings.other_offer_name }}</span>
                  {% endif %}
                </div>
              {% endif %}
            </div>
          {% else %}
            <div class="flex flex-col justify-center gap-2">
              {% if amount_to_freeshipping <= 0 and amount_to_freegift <= 0 and settings.order_amount_freeshipping != blank and settings.order_amount_freegift != blank and freeshipping_threshold and freegift_threshold %}
                <div class="flex items-center gap-2">
                  <div class="w-5 h-5 shrink-0">{% render 'icon-alls', icon: 'icon-gift' %}</div>
                  <span>{{ 'general.cart.free_all_offer' | t: other_offer: settings.other_offer_name }}</span>
                </div>
              {% else %}
                {% if amount_to_freeshipping <= 0 and settings.order_amount_freeshipping != blank and freeshipping_threshold %}
                  <div class="flex items-center gap-2">
                    <div class="w-5 h-5 shrink-0">{% render 'icon-labels-bags', icon: 'delivery-truck' %}</div>
                    <span>{{ 'general.cart.freeshipping' | t }}</span>
                  </div>
                {% endif %}
                {% if amount_to_freegift <= 0 and settings.order_amount_freegift != blank and freegift_threshold %}
                  <div class="flex items-center gap-2">
                    <div class="w-5 h-5 relative shrink-0">
                      {% if settings.custom_image_icon_other_offer != blank %}
                        {% # theme-check-disable ImgLazyLoading %}
                        <img
                          src="{{ settings.custom_image_icon_other_offer | image_url: width: 20 }}"
                          alt="{{ settings.custom_image_icon_other_offer.alt | escape }}"
                          {% if settings.enable_lazy_loading_image %}loading="lazy"{% else %}loading="eager"{% endif %}
                          onload="this.closest('.skeleton-image')?.classList.remove('animate-Xpulse', 'skeleton-image');"
                          width="{{ settings.custom_image_icon_other_offer.width }}"
                          height="{{ settings.custom_image_icon_other_offer.height }}"
                          style="object-position: {{ settings.custom_image_icon_other_offer.presentation.focal_point }}"
                          class="object-cover absolute top-0 left-0 w-full h-full{% if settings.custom_image_icon_other_offer != blank %} animate-Xpulse skeleton-image{% endif %}"
                        >
                        {% # theme-check-enable ImgLazyLoading %}
                      {% else %}
                        {% if settings.custom_icon_other_offer == blank %}
                          {% if settings.another_icon_other_offer != blank and settings.icon_other_offer == 'another_icon' %}
                            {% render 'icon-new-alls', icon: settings.another_icon_other_offer %}
                          {% else %}
                            {% render 'icon-labels-bags', icon: settings.icon_other_offer %}
                          {% endif %}
                        {% else %}
                          {{ settings.custom_icon_other_offer }}
                        {% endif %}
                      {% endif %}
                    </div>
                    <span>{{ 'general.cart.freegift' | t: other_offer: settings.other_offer_name }}</span>
                  </div>
                {% endif %}
              {% endif %}
            </div>
          {% endif %}
          {% if freeshipping_threshold or freegift_threshold %}
            <div class="w-full mt-5 relative">
              <div class="h-0.5 bg-[rgb(var(--colors-line-and-border))] rounded-full w-full"></div>
              <div :class="active && 'active'" class="absolute left-0 rtl:left-auto rtl:right-0 top-0 h-0.5 rounded-full bg-[rgb(var(--color-success))] free-offer-bar"></div>
              {% if settings.order_amount_freeshipping != blank and settings.order_amount_freegift != blank and freeshipping_threshold and freegift_threshold %}
                <div class="x-icon-shipping icon-shipping-position w-5 absolute top-0 transform -translate-y-1/2 -translate-x-1/2 rtl:translate-x-1/2 mt-0.5">
                  <div class="inline-flex items-center gap-1 bg-[rgb(var(--background-color))] border{% if amount_to_freeshipping > 0 %} text-[rgb(var(--colors-text))] border-[rgb(var(--colors-text))]{% else %} text-[rgb(var(--color-success))] border-[rgb(var(--color-success))]{% endif %} rounded-full pr-1 pl-1 pt-1 pb-1">
                    <div class="w-5 h-5">{% render 'icon-labels-bags', icon: 'delivery-truck' %}</div>
                  </div>
                </div>
              {% endif %}
              {% if settings.order_amount_freegift != blank and settings.order_amount_freeshipping != blank and freeshipping_threshold and freegift_threshold %}
                <div class="x-icon-offer icon-offer-position w-5 absolute top-0 transform -translate-y-1/2 -translate-x-1/2 rtl:translate-x-1/2 mt-0.5">
                  <div class="inline-flex items-center gap-1 bg-[rgb(var(--background-color))] border{% if amount_to_freegift > 0 %} text-[rgb(var(--colors-text))] border-[rgb(var(--colors-text))]{% else %} text-[rgb(var(--color-success))] border-[rgb(var(--color-success))]{% endif %} rounded-full pr-1 pl-1 pt-1 pb-1">
                    <div class="w-5 h-5 relative">
                      {% if settings.custom_image_icon_other_offer != blank %}
                        {% # theme-check-disable ImgLazyLoading %}
                        <img 
                          src="{{ settings.custom_image_icon_other_offer | image_url: width: 16 }}"
                          alt="{{ settings.custom_image_icon_other_offer.alt | escape }}"
                          {% if settings.enable_lazy_loading_image %}loading="lazy"{% else %}loading="eager"{% endif %}
                          onload="this.closest('.skeleton-image')?.classList.remove('animate-Xpulse', 'skeleton-image');"
                          width="{{ settings.custom_image_icon_other_offer.width }}"
                          height="{{ settings.custom_image_icon_other_offer.height }}"
                          style="object-position: {{ settings.custom_image_icon_other_offer.presentation.focal_point }}"
                          class="object-cover absolute top-0 left-0 w-full h-full rounded-full{% if settings.custom_image_icon_other_offer != blank %} animate-Xpulse skeleton-image{% endif %}"
                        >
                        {% # theme-check-enable ImgLazyLoading %}
                      {% else %}
                        {% if settings.custom_icon_other_offer == blank %}
                          {% if settings.another_icon_other_offer != blank and settings.icon_other_offer == 'another_icon' %}
                            {% render 'icon-new-alls', icon: settings.another_icon_other_offer %}
                          {% else %}
                            {% render 'icon-labels-bags', icon: settings.icon_other_offer %}
                          {% endif %}
                        {% else %}
                          {{ settings.custom_icon_other_offer }}
                        {% endif %}
                      {% endif %}
                    </div>
                  </div>
                </div>
              {% endif %}
            </div>
          {% endif %}
        </div>
      </div>
    {% endif %}
  {% endif %}
{%- endif -%}