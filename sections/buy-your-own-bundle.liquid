{% liquid
  assign heading_size = section.settings.heading_size | times: settings.heading_base_size | times: 0.000225
  if settings.edges_type == 'rounded_corners'
    assign rounded_corner = true
  endif
  if settings.lang_direction contains request.locale.iso_code
    assign is_rtl = true
  else
    assign is_rtl = false
  endif

  assign goal_1_threshold = ''
  assign goal_2_threshold = ''
  assign goal_3_threshold = ''

  if section.settings.goal_1 != blank
    assign thresholds = section.settings.goal_1 | newline_to_br | strip_newlines | split: '<br />'

    for threshold in thresholds
      unless threshold contains ':' 
        assign check_currency_1 = threshold | remove: "0" | remove: "1" | remove: "2" | remove: "3" | remove: "4" | remove: "5" | remove: "6" | remove: "7" | remove : "8" | remove: "9" | remove: ":" | remove: " "
        if check_currency_1 == '' or check_currency_1 == '.'
          assign threshold_all_1 = threshold | strip | plus: 0
        endif
      else
        assign check_currency_1_first = threshold | split: ":" | first 
        assign check_currency_1_last = threshold | split: ":" | last 
        assign check_currency_1 = threshold | remove_first: check_currency_1_first | remove: check_currency_1_last
        if check_currency_1 == ':'
          if check_currency_1_first == cart.currency.iso_code
            assign threshold_currency_1 = check_currency_1_last | strip | plus: 0
          endif 
        else
          assign check_currency_1_country = check_currency_1 | remove: ":"
          if check_currency_1_first == localization.country.iso_code and check_currency_1_country == cart.currency.iso_code
            assign threshold_country_1 = check_currency_1_last | strip | plus: 0
          endif
        endif 
      endunless
    endfor

    if threshold_all_1
      assign goal_1_threshold = threshold_all_1
    endif 
    if threshold_currency_1
      assign goal_1_threshold = threshold_currency_1
    endif 
    if threshold_country_1
      assign goal_1_threshold = threshold_country_1
    endif 
  endif

  if section.settings.goal_2 != blank
    assign thresholds = section.settings.goal_2 | newline_to_br | strip_newlines | split: '<br />'
    for threshold in thresholds
      unless threshold contains ':' 
        assign check_currency_2 = threshold | remove: "0" | remove: "1" | remove: "2" | remove: "3" | remove: "4" | remove: "5" | remove: "6" | remove: "7" | remove : "8" | remove: "9" | remove: ":" | remove: " "
        if check_currency_2 == '' or check_currency_2 == '.'
          assign threshold_all_2 = threshold | strip | plus: 0
        endif
      else
        assign check_currency_2_first = threshold | split: ":" | first 
        assign check_currency_2_last = threshold | split: ":" | last 
        assign check_currency_2 = threshold | remove_first: check_currency_2_first | remove: check_currency_2_last
        if check_currency_2 == ':'
          if check_currency_2_first == cart.currency.iso_code
            assign threshold_currency_2 = check_currency_2_last | strip | plus: 0
          endif 
        else
          assign check_currency_2_country = check_currency_2 | remove: ":"
          if check_currency_2_first == localization.country.iso_code and check_currency_2_country == cart.currency.iso_code
            assign threshold_country_2 = check_currency_2_last | strip | plus: 0
          endif
        endif 
      endunless
    endfor

    if threshold_all_2
      assign goal_2_threshold = threshold_all_2
    endif 
    if threshold_currency_2
      assign goal_2_threshold = threshold_currency_2
    endif 
    if threshold_country_2
      assign goal_2_threshold = threshold_country_2
    endif 
  endif

  if section.settings.goal_3 != blank
    assign thresholds = section.settings.goal_3 | newline_to_br | strip_newlines | split: '<br />'
    for threshold in thresholds
      unless threshold contains ':' 
        assign check_currency_3 = threshold | remove: "0" | remove: "1" | remove: "2" | remove: "3" | remove: "4" | remove: "5" | remove: "6" | remove: "7" | remove : "8" | remove: "9" | remove: ":" | remove: " "
        if check_currency_3 == '' or check_currency_3 == '.'
          assign threshold_all_3 = threshold | strip | plus: 0
        endif
      else
        assign check_currency_3_first = threshold | split: ":" | first 
        assign check_currency_3_last = threshold | split: ":" | last 
        assign check_currency_3 = threshold | remove_first: check_currency_3_first | remove: check_currency_3_last
        if check_currency_3 == ':'
          if check_currency_3_first == cart.currency.iso_code
            assign threshold_currency_3 = check_currency_3_last | strip | plus: 0
          endif 
        else
          assign check_currency_3_country = check_currency_3 | remove: ":"
          if check_currency_3_first == localization.country.iso_code and check_currency_3_country == cart.currency.iso_code
            assign threshold_country_3 = check_currency_3_last | strip | plus: 0
          endif
        endif 
      endunless
    endfor

    if threshold_all_3
      assign goal_3_threshold = threshold_all_3
    endif 
    if threshold_currency_3
      assign goal_3_threshold = threshold_currency_3
    endif 
    if threshold_country_3
      assign goal_3_threshold = threshold_country_3
    endif 
  endif
%}
{% style %}
  .step-title-container {
    --color-highlight: {{ settings.colors_heading_highlight.red }}, {{ settings.colors_heading_highlight.green }}, {{ settings.colors_heading_highlight.blue }}
  }
  .dark .step-title-container {
    --color-highlight: {{ settings.colors_dark_heading_highlight.red }}, {{ settings.colors_dark_heading_highlight.green }}, {{ settings.colors_dark_heading_highlight.blue }}
  }
  .step-icon-{{ section.id }} {       
    width: {{ section.settings.step_icon_size | times: 0.8 }}px;
    height: {{ section.settings.step_icon_size | times: 0.8 }}px;
  }
  .step-title-container.scrollbar-body::-webkit-scrollbar{
    width: 1px;
    height: 2px;
  }
  @media (min-width: 768px) {
    .step-icon-{{ section.id }} {       
      width: {{ section.settings.step_icon_size }}px;
      height: {{ section.settings.step_icon_size }}px;
    }
  }
  {% if request.visual_preview_mode %}
    .step-icon-size {
      width: {{ section.settings.step_icon_size }}px;
      height: {{ section.settings.step_icon_size }}px;
    }
  {% endif %}
  .gap-{{ section.id }} {
    gap: {{ section.settings.spacing_mobile }}px;
  }
  @media screen and (min-width: 768px) {
    .gap-{{ section.id }}  {
      gap: {{ section.settings.spacing }}px;
    }
  }
{% endstyle %}

{% render 'section-divider' %}

{%- paginate pages by 1 -%}
  <div 
    x-intersect.once="initByob()" 
    x-data="xBuyOwnBundle('{{ section.id }}', '{{ paginate.page_param }}', $el, {% if settings.currency_code_enable %}'{{ shop.money_with_currency_format | escape }}'{% else %}'{{ shop.money_format | escape }}'{% endif %}, '{{ section.settings.summary_layout }}', '{{ section.blocks.size }}', 
    '{{ goal_1_threshold }}', '{{ goal_2_threshold }}', '{{ goal_3_threshold }}', 
    '{{ section.settings.goal_1_label }}', '{{ section.settings.goal_2_label }}', '{{ section.settings.goal_3_label }}', 
    '{{ section.settings.discount_type_1 }}', '{{ section.settings.discount_type_2 }}', '{{ section.settings.discount_type_3 }}', 
    '{{ section.settings.discount_value_1 }}', '{{ section.settings.discount_value_2 }}', '{{ section.settings.discount_value_3 }}', 
    {{ section.settings.apply_discount_once_per_order_1 }}, {{ section.settings.apply_discount_once_per_order_2 }}, {{ section.settings.apply_discount_once_per_order_3 }}, '{{ section.settings.pre_goal_msg }}', '{{ section.settings.caculate_discount_by }}', '{{ cart.currency.iso_code }}')" 
    class="x-container-byob x-byob-{{ section.id }} pt-[{{ section.settings.padding_top_mobile }}px] md:pt-[{{ section.settings.padding_top }}px] pb-[{{ section.settings.padding_bottom_mobile }}px] md:pb-[{{ section.settings.padding_bottom }}px] {% unless section.settings.full_width %} x-pgw page-width{% endunless %} pr-5 pl-5"
  >
    {%- if section.settings.heading != blank or section.settings.text != blank or section.settings.subheading != blank or section.blocks.size > 0 -%}
      {%- style -%}      
        .heading-{{ section.id }} { 
          font-size: {{ heading_size | times: 0.6 }}rem; 
          {% if section.settings.heading_color_light.alpha != 0.0 %}
            --colors-heading: {{ section.settings.heading_color_light.red }},{{ section.settings.heading_color_light.green }},{{ section.settings.heading_color_light.blue }};
          {% else %}
            --colors-heading: {{ settings.colors_heading.red }},{{ settings.colors_heading.green }},{{ settings.colors_heading.blue }};
          {%- endif -%}
        }
        .progress-bar-container-{{ section.id }} {
          {% if section.settings.color_marker_light.alpha != 0.0 %}
            --color-highlight: {{ section.settings.color_marker_light }};
          {% else %}
            --color-highlight: {{ settings.colors_heading_highlight }}
          {% endif %}
        }
        .dark .heading-{{ section.id }} {
          {% if section.settings.heading_color_dark.alpha != 0.0 %}
            --colors-heading: {{ section.settings.heading_color_dark.red }},{{ section.settings.heading_color_dark.green }},{{ section.settings.heading_color_dark.blue }};
          {% else %}
            --colors-heading: {{ settings.colors_dark_heading.red }},{{ settings.colors_dark_heading.green }},{{ settings.colors_dark_heading.blue }};
          {% endif %}
        }
        .dark .progress-bar-container-{{ section.id }} {
          {% if section.settings.color_marker_dark.alpha != 0.0 %}
            --color-highlight: {{ section.settings.color_marker_dark }};
          {% else %}
            --color-highlight: {{ settings.colors_dark_heading_highlight }}
          {% endif %}
        }
        @media screen and (min-width: 768px) {
          .heading-{{ section.id }}{ font-size: {{ heading_size }}rem; }
        }
        .color-text--{{ section.id }} {
          {% if section.settings.text_color_light.alpha != 0.0 %}
            color: {{ section.settings.text_color_light }};
          {% else %}
            color: {{ settings.colors_text }};
          {% endif %}
        }
        .dark .color-text--{{ section.id }} {
          {% if section.settings.text_color_dark.alpha != 0.0 %}
            color: {{ section.settings.text_color_dark }};
          {% else %}
            color: {{ settings.colors_dark_text }};
          {% endif %}
        }
      {%- endstyle -%}
      <div 
        class="x-block-byob-header mb-5 md:mb-9 text-{{ section.settings.heading_alignment }} rtl:text-{% if section.settings.heading_alignment == 'center' %}center{% elsif section.settings.heading_alignment == 'left' %}right{% else %}left{% endif %}"
      >
        {%- if section.settings.subheading != blank -%}
          <div class="mb-1.5{% unless settings.disable_heading_animation %} overflow-hidden{% endunless %}"{% unless settings.disable_heading_animation %} x-intersect.once="$el.querySelector('.anm-move-up')?.classList.add('active-anm-heading')"{% endunless %}>
            <p class="rte color-text--{{ section.id }}{% unless settings.disable_heading_animation %} anm-move-up{% endunless %}">{{ section.settings.subheading }}</p>
          </div>
        {% endif %}
        {%- if section.settings.heading != blank -%}
          <div class="pt-2 pb-2">
            {% render 'heading-highlight',
              headingId: section.id,
              heading: section.settings.heading,
              highlight_type: section.settings.highlight_type,
              color_heading_highlight_light: section.settings.color_marker_light,
              color_heading_highlight_dark: section.settings.color_marker_dark,
              class: 'h2 block leading-tight',
              heading_tag: section.settings.heading_tag,
              animation_heading: true
            %}
          </div>
        {%- endif -%}
        {%- if section.settings.text != blank -%}
          <div class="rte mt-2 mb-6 lg:mb-12 color-text--{{ section.id }}">{{ section.settings.text }}</div>
        {% endif %}
      </div>      
    {%- endif -%}
    {% if section.blocks.size > 0 %}
      <div 
        class="step-title-container block md:block h-auto relative md:mb-9 mb-2 overflow-x-auto overflow-y-hidden scrollbar-body scrollbar-stable self-center min-w-[30%] w-full"
      >
        <div class="flex flex-row md:flex-wrap items-center h-full gap-2 md:gap-4{% if section.settings.heading_alignment == 'right' %} md:justify-end{% elsif section.settings.heading_alignment == 'left' %} md:justify-start{% else %} md:justify-center{% endif %}">
          {%- for block in section.blocks -%}
            <div
              tabindex="0"
              :class="currentTab == {{ forloop.index }} ? 'border-[rgba(var(--color-highlight))]' : 'opacity-60 border-transparent'"
              @keydown.enter.prevent="setTimeout(() => {select({{ forloop.index }})}, 0)"
              @click="setTimeout(() => {select({{ forloop.index }})}, 0)"
              {% unless forloop.first %}
                x-intersect.once='loadData({{ forloop.index }})'
              {% else %}
                {% if paginate.current_page > 1 %}
                  x-intersect.once='loadData({{ forloop.index }})'
                {% endif %}
              {% endunless %}
              class="step-title flex gap-3 items-center max-w-[75%] pr-6 pb-3 cursor-pointer md:border-b"
            >
              {%- if block.settings.icon != 'none' -%}
                {% unless block.settings.custom_image == blank and block.settings.custom_icon == blank and block.settings.another_icon == blank and block.settings.icon == 'another_icon' %}
                  <span 
                    :class="currentTab == {{ forloop.index }} ? 'text-[rgba(var(--colors-background))] border-[rgba(var(--color-highlight))] bg-[rgba(var(--color-highlight))]' : 'bg-[rgba(var(--colors-background-secondary))] border-[rgb(var(--colors-text))]'"
                    class="inline-block flex-shrink-0 step-icon-{{ section.id }} step-icon-size p-1.5 rounded-full border"
                  >
                    {% if block.settings.custom_image != blank %}
                      {% # theme-check-disable ImgLazyLoading %}
                      <img 
                        src="{{ block.settings.custom_image | image_url: width: 30 }}"
                        alt="{{ block.settings.custom_image.alt | escape }}"
                        {% if settings.enable_lazy_loading_image %}loading="lazy"{% else %}loading="eager"{% endif %}
                        width="{{ block.settings.custom_image.width }}"
                        height="{{ block.settings.custom_image.height }}"
                        style="object-position: {{ block.settings.custom_image.presentation.focal_point }}"
                        class="object-cover w-full h-full rounded-full"
                      >
                      {% # theme-check-enable ImgLazyLoading %}
                    {% else %}
                      {% if block.settings.custom_icon == blank %}
                        {% if block.settings.another_icon != blank and block.settings.icon == 'another_icon' %}
                          {% render 'icon-new-alls', icon: block.settings.another_icon %}
                        {% else %}
                          {% render 'icon-labels-bags', icon: block.settings.icon %}
                        {% endif %}
                      {% else %}
                        {{ block.settings.custom_icon }}
                      {% endif %}
                    {% endif %}
                  </span>
                {% endunless %}
              {% endif %}
              <span 
                class="label-{{ section.id }} inline-block h4 text-sm whitespace-nowrap cursor-pointer w-full overflow-hidden text-ellipsis md:leading-none md:text-[120%] duration-300
                {%- if section.blocks.size > 1 %} leading-snug{% endif -%}"
              >
                {{ block.settings.step_title }}
              </span>
            </div>
          {%- endfor -%}
        </div>
      </div>
    {% endif %}

    {% liquid
      assign block_index = paginate.current_page | minus: 1
      if section.blocks.size == 1
        assign block_index = 0
      endif
      assign block = section.blocks[block_index]
    %}
    <div class="relative">
      <div 
        id="x-byob-content-{{ section.id }}" 
        class="flex flex-col md:flex-row {% if section.settings.summary_layout != 'vertical' %}md:mb-9{% endif %} {% if section.settings.summary_layout == 'vertical' %}{% if section.settings.summary_position == "left" %} md:flex-row-reverse rtl:md:flex-row{% else %} md:flex-row rtl:md:flex-row-reverse{% endif %}{% endif %}{% if is_rtl %} ltr{% endif %} gap-{{ section.id }}"
        x-intersect.once='$el.classList.add("is-ready-to-animate")'
      >
        {% liquid
          assign enable_desktop_slider = false
          assign swiper_on_mobile = false

          if block.settings.products != blank
            assign product_count = block.settings.products.count
          elsif block.settings.collection.products_count != 0 and block.settings.collection != blank
            if block.settings.product_to_show < block.settings.collection.products_count
              assign product_count = block.settings.product_to_show
            else
              assign product_count = block.settings.collection.products_count
            endif
          else
            if section.settings.summary_layout != 'vertical' 
              assign product_count = 4
            else
              assign product_count = 3
            endif
          endif

          if block.settings.enable_promotion_highlight == false and section.settings.summary_layout != 'vertical'
            if section.settings.enable_desktop_slider and product_count > 4
              assign enable_desktop_slider = true
            endif
          elsif block.settings.enable_promotion_highlight and section.settings.summary_layout == 'vertical'
            if section.settings.enable_desktop_slider and product_count > 2
              assign enable_desktop_slider = true
            endif
          else 
            if section.settings.enable_desktop_slider and product_count > 3 
              assign enable_desktop_slider = true
            endif
          endif
          if section.settings.swiper_on_mobile
            if section.settings.columns_mobile == '1' and product_count > 1
              assign swiper_on_mobile = true
            elsif section.settings.columns_mobile == '2' and product_count > 2
              assign swiper_on_mobile = true
            endif
          endif

          assign width_class_content = 'w-full'
          assign width_class_summary = 'w-full'
          assign width_class_promotion = 'w-full'
          if section.settings.summary_layout == 'vertical'
            if block.settings.enable_promotion_highlight
              if enable_desktop_slider
                assign width_class_content = 'w-full md:w-1/2 lg:w-1/2'
                assign width_class_promotion = 'w-full md:w-1/4 lg:w-1/4'
                assign width_class_summary = 'w-full md:w-1/4 lg:w-1/4'  
              else
                assign width_class_content = 'w-full md:w-2/3 lg:w-3/4'
                assign width_class_summary = 'w-full md:w-1/3 lg:w-1/4'  
              endif
            else 
              assign width_class_content = 'w-full md:w-2/3 lg:w-3/4'
              assign width_class_summary = 'w-full md:w-1/3 lg:w-1/4'  
            endif
          else 
            if block.settings.enable_promotion_highlight and enable_desktop_slider
              assign width_class_content = 'w-full md:w-3/4'
              assign width_class_promotion = 'w-full md:w-1/4'
            endif
          endif

          assign display_class_promotion = ''
          assign display_class_promotion_grid_item = ''

          if enable_desktop_slider
            if swiper_on_mobile
              assign display_class_promotion = 'grid'
              assign display_class_promotion_grid_item = 'hidden'
            else
              assign display_class_promotion = 'md:grid hidden'
              assign display_class_promotion_grid_item = 'grid md:hidden'
            endif
          else
            if swiper_on_mobile
              assign display_class_promotion = 'md:hidden grid'
              assign display_class_promotion_grid_item = 'md:grid hidden'
            else
              assign display_class_promotion = 'hidden'
              assign display_class_promotion_grid_item = 'grid'
            endif
          endif
        %}

        {% if block.settings.enable_promotion_highlight %}
          {% capture promotion_block %}
            {% liquid
              assign image = block.settings.image
              if block.settings.image_mobile != blank
                assign image = block.settings.image_mobile
              endif
            %}
            {% style %}
              .x-byob-{{ section.id }} .promotion-block {
                --colors-text: var(--colors-text-secondary);
                --colors-heading: var(--colors-text-secondary);
              }
              {% if image != blank and swiper_on_mobile or swiper_on_mobile == false and section.settings.columns_mobile != '2' %}
                @media (max-width: 767px) {
                  .bundle-promotion-{{ block.id }} {
                    height: calc((100vw - 40px) * {{ 1 | divided_by: image.aspect_ratio }});
                  }
                }
              {% endif %}
            {% endstyle %}
            {% liquid
              assign col_span = block.settings.number_of_columns
              unless section.settings.summary_layout == 'horizontal'
                if col_span > 3
                  assign col_span = 3
                endif
              endunless
              assign col_span_mobile = block.settings.number_of_columns_mobile
              if col_span_mobile > section.settings.columns_mobile
                assign col_span_mobile = section.settings.columns_mobile
              endif
              assign class_tall_mobile = 'col-span-' | append: col_span_mobile | append: ' row-span-' | append: block.settings.number_of_row_mobile
              assign class_tall_desktop = 'lg:col-span-' | append: col_span | append: ' lg:row-span-' | append: block.settings.number_of_row
              assign col_span = col_span | times: 1.0
              assign columns_desktop = 3 | divided_by: col_span
              assign columns_mobile = section.settings.columns_mobile | divided_by: col_span_mobile
              if settings.enable_lazy_loading_image == false
                assign loading = 'eager'
              else
                assign loading = 'lazy'
              endif
              assign ratio = 'square'
              if block.settings.image != blank or block.settings.image_mobile != blank
                assign ratio = 'natural'
              endif
            %}
            {% render 'promotion-block',
              blockID: block.id,
              image_ratio: ratio,
              columns_desktop: columns_desktop,
              columns_mobile: columns_mobile,
              block: block,
              enable_desktop_slider: false,
              image: block.settings.image,
              button_label: block.settings.button_label,
              button_link: block.settings.button_link,
              open_new_window: block.settings.open_new_window,
              content_position: block.settings.content_position,
              alignment: block.settings.alignment,
              heading: block.settings.heading,
              content: block.settings.content,
              image_overlay_opacity: block.settings.image_overlay_opacity,
              title_size: block.settings.title_size,
              text_size: block.settings.text_size,
              list_layout: true,
              show_button_style: block.settings.show_button_style,
              color_button: block.settings.color_button,
              color_text_button: block.settings.color_text_button,
              color_button_hover: block.settings.color_button_hover,
              color_text_button_hover: block.settings.color_text_button_hover,
              color_button_secondary: block.settings.color_button_secondary,
              secondary_button_text: block.settings.secondary_button_text,
              colors_text_link: block.settings.colors_text_link,
              class_tall_mobile: class_tall_mobile,
              class_tall_desktop: class_tall_desktop,
              loading: loading,
              icon: 'none',
              subheading: block.settings.subheading,
              heading_highlight: true,
              color_heading_highlight_dark: block.settings.color_heading_highlight_dark,
              color_heading_highlight_light: block.settings.color_heading_highlight_light,
              highlight_type: block.settings.highlight_type
            %}
          {% endcapture %} 
        {% endif %}

        {% liquid
          assign progress_bar = 3
          if block.settings.products != blank
            assign progress_bar = product_count
          elsif block.settings.collection.products.size > 0
            assign progress_bar = product_count
          endif
        %}
        {% style %}
          {% if swiper_on_mobile %}
            .bundle-splide-slide-{{ section.id }}-{{block.id}} {
              {%- if settings.lang_direction contains request.locale.iso_code %} 
                margin-left: {{ section.settings.spacing_mobile }}px;
              {% else %}
                margin-right: {{ section.settings.spacing_mobile }}px;
              {% endif %}
              width: calc(((100% + {{ section.settings.spacing_mobile }}px) / {{ section.settings.columns_mobile }}) - {{ section.settings.spacing_mobile }}px);
            }
          {% endif %}
          {% if enable_desktop_slider %}
            @media (min-width: 768px) {
              .bundle-splide-slide-{{ section.id }}-{{block.id}} {
                {%- if settings.lang_direction contains request.locale.iso_code %} 
                  margin-left: {{ section.settings.spacing }}px;
                {% else %}
                  margin-right: {{ section.settings.spacing }}px;
                {% endif %}
                {% liquid 
                  assign columns_desktop = ''
                  assign preload_width = 100
                  if section.settings.summary_layout != 'vertical'
                    if block.settings.products.size > 0
                      if block.settings.products.size == 2 
                        assign preload_width = 50
                        assign columns_desktop = 2
                      elsif block.settings.products.size == 3
                        assign preload_width = 33.33
                        assign columns_desktop = 3
                      else
                        if block.settings.enable_promotion_highlight
                          assign preload_width = 33.33
                          assign columns_desktop = 3
                        else
                          assign preload_width = 25
                          assign columns_desktop = 4
                        endif
                      endif
                    elsif block.settings.collection.products.size > 0
                      if block.settings.collection.products.size == 2 
                        assign preload_width = 50
                        assign columns_desktop = 2
                      elsif block.settings.collection.products.size == 3
                        assign preload_width = 33.33
                        assign columns_desktop = 3
                      else
                        if block.settings.enable_promotion_highlight
                          assign preload_width = 33.33
                          assign columns_desktop = 3
                        else
                          assign preload_width = 25
                          assign columns_desktop = 4
                        endif
                      endif
                    endif
