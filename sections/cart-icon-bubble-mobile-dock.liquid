<div id="cart-icon-bubble-mobile-dock" class="count_item absolute -top-[20%] left-[60%]" data-value="{{ cart.item_count }}">
  <div class="bg-[rgba(var(--colors-cart))] text-[rgba(var(--colors-cart-text))] font-medium h-4 w-4 rounded-full text-[10px]{% if cart == empty %} hidden{% endif %}">
    {% if cart.item_count < 100 %}
      <span class="h-full flex items-center justify-center mt-[1px]" aria-hidden="true">{{ cart.item_count }}</span>
    {% else %}
      <span class="h-full flex items-center justify-center mt-[1px]">99+</span> 
    {% endif %}
  </div>
</div>
