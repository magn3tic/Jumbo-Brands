                </div>
                {%- if section.settings.bundler_text != blank -%}
                  <div class="rte subheading text-medium text-[rgba(var(--colors-text))] mt-1.5">{{ section.settings.bundler_text }}</div>
                {%- endif -%}
              </div>

              {% liquid
                assign text_size = settings.text_base_size | times: 0.00875
                assign text_size_mobile = settings.text_base_size | times: 0.007875

                assign available_goal_list = ''
                assign goal_count = 0
                if goal_1_threshold != blank
                  assign goal_count = goal_count | plus: 1
                  assign available_goal_list = available_goal_list | append: 'goal_1,'
                endif
                if goal_2_threshold != blank
                  assign goal_count = goal_count | plus: 1
                  assign available_goal_list = available_goal_list | append: 'goal_2,'
                endif
                if goal_3_threshold != blank
                  assign goal_count = goal_count | plus: 1
                  assign available_goal_list = available_goal_list | append: 'goal_3'
                endif

                assign available_goal_list = available_goal_list | split: ','
              %}
              <div x-cloak x-show="!allGoalReached && !loadPrevGoalMsg" x-text="prevGoalMsg" class="rte w-full subheading prev-goal-msg text-medium text-[rgba(var(--colors-text))] mt-2"></div>
              {% if goal_count > 0 %}
                <div class="discount-progress-bar-{{ section.id }} w-full">
                  {% style %}
                    {% if section.settings.goal_1_label != blank or section.settings.goal_2_label != blank or section.settings.goal_3_label != blank %}
                      {% if goal_count > 1 %}
                        .padding-text-{{ section.id }} {
                          padding-bottom: {{ text_size_mobile | times: 1.375 | plus: 0.25 }}rem;
                        }
                        @media (min-width: 768px) {
                          .padding-text-{{ section.id }} {
                            padding-bottom: {{ text_size | times: 1.375 | plus: 0.25 }}rem;
                          }
                        }  
                      {% endif %}
                    {% endif %}
                    {% if goal_count == 3 %}
                      .progress-bar-container-{{ section.id }} .discount-progress-{{ section.id }}:first-child {
                        width: 12%;
                        flex: unset
                      }
                    {% endif %}
                    .discount-progress-{{ section.id }}::after {
                      content: "";
                      position: absolute;
                      border-top-width: 4px;
                      top: -4px;
                      width: var(--progress);
                      max-width: 100%;
                      border-color: var(--color-highlight);
                      {% if rounded_corner and goal_count == 1 %}
                        border-radius: 9999px
                      {% endif %}
                    }    
                    {% if rounded_corner %}
                      .discount-progress-{{ section.id }}:first-child, .discount-progress-{{ section.id }}:first-child::after {
                        border-top-left-radius: 9999px;
                        border-bottom-left-radius: 9999px;
                      }
                      .discount-progress-{{ section.id }}.end-progress, .discount-progress-{{ section.id }}.end-progress::after {
                        border-top-right-radius: 9999px;
                        border-bottom-right-radius: 9999px;
                      }
                    {% endif %}
                    .goal-reached-{{ section.id }} {
                      background: var(--color-highlight);
                      color: rgba(var(--colors-background))
                    }
                    .progress-bar-container-{{ section.id }}{
                      {% if section.settings.line_border_light.alpha != 0.0 %}
                        --colors-line-and-border: {{ section.settings.line_border_light.red }},{{ section.settings.line_border_light.green }},{{ section.settings.line_border_light.blue }};
                      {% else %}
                        --colors-line-and-border: {{ settings.colors_line_and_borders.red }}, {{ settings.colors_line_and_borders.green }}, {{ settings.colors_line_and_borders.blue }};
                      {% endif %}
                    }
                    .dark .progress-bar-container-{{ section.id }} {
                      {% if section.settings.line_border_dark.alpha != 0.0 %}
                        --colors-line-and-border: {{ section.settings.line_border_dark.red }},{{ section.settings.line_border_dark.green }},{{ section.settings.line_border_dark.blue }};
                      {% else %}        
                        --colors-line-and-border: {{ settings.colors_dark_line_and_borders.red }}, {{ settings.colors_dark_line_and_borders.green }}, {{ settings.colors_dark_line_and_borders.blue }};
                      {% endif %}
                    }
                  {% endstyle %}
                  <div x-cloak x-show="allGoalReached" class="rte subheading goal-reached-msg text-medium text-[rgba(var(--colors-text))] mt-2">{{ section.settings.reach_goal_msg }}</div>
                  <div x-cloak x-show="!loadDiscountBar" class="progress-bar-container-{{ section.id }} flex relative w-full items-center padding-text-{{ section.id }} pt-4">
                    {% if goal_count > 1 %}
                      {% if goal_1_threshold != '' %}
                        <div class="border-t-4 flex-1 progress-goal-1 discount-progress-{{ section.id }} relative"></div>
                        <div class="goal-destination-1 flex flex-col gap-1 relative items-center">
                          <div x-cloak {% if section.settings.caculate_discount_by == 'quantity' %}x-show="productsBundle.length < {{ goal_1_threshold }}"{% else %}x-show="productsBundle.map(item => item.price).reduce((total, item) => total + item, 0)/100 < {{ goal_1_threshold }}"{% endif %} class="w-4 h-4 rounded-full border"></div>
                          <div x-cloak {% if section.settings.caculate_discount_by == 'quantity' %}x-show="productsBundle.length >= {{ goal_1_threshold }}"{% else %}x-show="productsBundle.map(item => item.price).reduce((total, item) => total + item, 0)/100 >= {{ goal_1_threshold }}"{% endif %} class="w-4 h-4 goal-reached-{{ section.id }} rounded-full flex justify-center items-center">
                            <span class="w-2.5 h-2.5 block">
                              {% render 'icon-alls', icon: 'icon-check' %}
                            </span>
                          </div>
                          {% if section.settings.goal_1_label != blank %}
                            <div class="goal-label-1 text-ellipsis overflow-hidden max-w-[86px] text-center absolute top-full pt-1 whitespace-nowrap">{{ section.settings.goal_1_label }}</div>
                          {% endif %}
                        </div>
                      {% endif %}
                      {% if goal_2_threshold != '' %}
                        <div class="border-t-4 flex-1 {% if goal_1_threshold == '' %}progress-goal-2{% else %}progress-pre-goal-2{% endif %} discount-progress-{{ section.id }} relative"></div>
                        <div class="goal-destination-2 flex flex-col gap-1 relative items-center">
                          <div x-cloak {% if section.settings.caculate_discount_by == 'quantity' %}x-show="productsBundle.length < {{ goal_2_threshold }}"{% else %}x-show="productsBundle.map(item => item.price).reduce((total, item) => total + item, 0)/100 < {{ goal_2_threshold }}"{% endif %} class="w-4 h-4 rounded-full border"></div>
                          <div x-cloak {% if section.settings.caculate_discount_by == 'quantity' %}x-show="productsBundle.length >= {{ goal_2_threshold }}"{% else %}x-show="productsBundle.map(item => item.price).reduce((total, item) => total + item, 0)/100 >= {{ goal_2_threshold }}"{% endif %} class="w-4 h-4 goal-reached-{{ section.id }} rounded-full flex justify-center items-center">
                            <span class="w-2.5 h-2.5 block">
                              {% render 'icon-alls', icon: 'icon-check' %}
                            </span>
                          </div>
                          {% if section.settings.goal_2_label != blank %}
                            <div class="goal-label-2 text-ellipsis overflow-hidden max-w-[86px] text-center absolute top-full pt-1 whitespace-nowrap">{{ section.settings.goal_2_label }}</div>
                          {% endif %}
                        </div>
                      {% endif %}
                      {% if goal_3_threshold != '' %}
                        <div class="border-t-4 flex-1 progress-pre-goal-3 discount-progress-{{ section.id }} relative"></div>
                        <div class="goal-destination-3 flex flex-col gap-1 relative items-center">
                          <div x-cloak {% if section.settings.caculate_discount_by == 'quantity' %}x-show="productsBundle.length < {{ goal_3_threshold }}"{% else %}x-show="productsBundle.map(item => item.price).reduce((total, item) => total + item, 0)/100 < {{ goal_3_threshold }}"{% endif %} class="w-4 h-4 rounded-full border"></div>
                          <div x-cloak {% if section.settings.caculate_discount_by == 'quantity' %}x-show="productsBundle.length >= {{ goal_3_threshold }}"{% else %}x-show="productsBundle.map(item => item.price).reduce((total, item) => total + item, 0)/100 >= {{ goal_3_threshold }}"{% endif %} class="w-4 h-4 goal-reached-{{ section.id }} rounded-full flex justify-center items-center">
                            <span class="w-2.5 h-2.5 block">
                              {% render 'icon-alls', icon: 'icon-check' %}
                            </span>
                          </div>
                          {% if section.settings.goal_3_label != blank %}
                            <div class="goal-label-3 text-ellipsis overflow-hidden max-w-[86px] text-center absolute top-full pt-1 whitespace-nowrap">{{ section.settings.goal_3_label }}</div>
                          {% endif %}
                        </div>
                      {% endif %}
                      <div class="border-t-4 end-progress w-[12%] discount-progress-{{ section.id }} relative"></div>
                    {% else %}
                      <div class="border-t-4 {% if rounded_corner %}rounded-full{% endif %} w-full progress-single-bar discount-progress-{{ section.id }} relative"></div>
                    {% endif %}
                  </div>
                </div>
              {% endif %}
              {% style %}
                .bundler-product-list-{{ section.id }} {
                  {% if section.settings.line_border_light.alpha != 0.0 %}
                    --colors-line-and-border: {{ section.settings.line_border_light.red }},{{ section.settings.line_border_light.green }},{{ section.settings.line_border_light.blue }};
                  {% else %}
                    --colors-line-and-border: {{ settings.colors_line_and_borders.red }}, {{ settings.colors_line_and_borders.green }}, {{ settings.colors_line_and_borders.blue }};
                  {% endif %}
                }
                .dark .bundler-product-list-{{ section.id }} {
                  {% if section.settings.line_border_dark.alpha != 0.0 %}
                    --colors-line-and-border: {{ section.settings.line_border_dark.red }},{{ section.settings.line_border_dark.green }},{{ section.settings.line_border_dark.blue }};
                  {% else %}        
                    --colors-line-and-border: {{ settings.colors_dark_line_and_borders.red }}, {{ settings.colors_dark_line_and_borders.green }}, {{ settings.colors_dark_line_and_borders.blue }};
                  {% endif %}
                }
              {% endstyle %}
              <div :class="openBundleSum ? 'block' : 'hidden'" class="bundler-product-list bundler-product-list-{{ section.id }} md:block max-h-[180px] pr-2 md:pr-0 md:max-h-full scrollbar-body scrollbar-visible overflow-x-hidden md:h-auto mt-4 w-full">
                {% if section.settings.summary_layout != 'vertical' and section.blocks.size > 1 %}
                <div
                  id="bundler-product-list-slide-horizontal-{{ section.id }}" 
                  class="x-splide splide w-full visible overflow-hidden flex flex-row"
                  x-data-slider="{{ section.id }}"
                  x-intersect.once.margin.200px='$store.xSplide.load($el, {
                    "speed": 1000,
                    "focus": 0,
                    "omitEnd": true,
                    "pagination": false, 
                    "mediaQuery": "min",
                    "updateOnMove": "true",
                    "autoWidth": true,
                    "gap": "0px",
                    {%- if settings.lang_direction contains request.locale.iso_code %} 
                      "direction": "rtl",
                    {%- endif %}
                    "breakpoints": {
                      300: {
                        "destroy": true
                      },
                      768: {
                        "destroy": false
                      }
                    },
                    "arrows": false
                  })'
                >
                  <div class="splide__track md:cursor-grab w-full lg:pl-0 lg:pr-0">
                    <div class="{% if request.visual_preview_mode %}md:gap-7 {% endif %}splide__list flex flex-col md:flex-row overflow-x-auto md:overflow-x-visible w-full">
                {% endif %}
                {% for block in section.blocks %}
                  <div id="bundler-product-list-item-step-{{ section.id }}-{{ forloop.index }}" class="bundler-product-list-item border-b pt-4 pb-4 {% if section.settings.summary_layout == 'vertical' %}md:border-b {% else %} md:border-b-0 md:pt-0 md:pb-0 splide__slide x-splide-slide {% unless forloop.last %}md:border-r{% endunless %} {% if forloop.first %} md:pr-6 {% else %} md:pl-6 md:pr-6 {% endif %}{% endif %}" 
                    x-data="{open: false }"
                    x-init="document.addEventListener(`eurus:byob:add-to-bundle-${sectionId}`, (event) => {
                      const newProduct = event.detail.newProduct;
                      if (newProduct.current_step == {{ forloop.index }}) {
                        open = true;
                      }
                    });
                    {% if section.settings.summary_layout != 'vertical' %}
                      $watch('openList', () => {
                        if (openList == false) {
                          open = false
                        }
                      });
                    {% endif %}"
                  >
                    {% liquid
                      assign min_required = block.settings.min_required | default: 0
                      assign max_required = block.settings.max_required | default: 0
                    %}
                    <div class="step-block-id hidden">{{ block.id }}</div>
                    <div class="hidden" id="step-max-condition-{{ section.id }}-{{ forloop.index }}">{{ max_required }}</div>               
                    <div class="step-min-condition-{{ section.id }} hidden" x-text="JSON.parse(JSON.stringify(productsBundle)).filter(item => item.current_step == {{ forloop.index }}).length >= {{ min_required }} ? 'true' : 'false'"></div>
                    <div class="relative cursor-pointer flex justify-between" @click="open = !open">
                      <div class="uppercase text-[rgb(var(--colors-text))]">{{ 'buy-your-own-bundle.step' | t: index: forloop.index }}</div> 
                      <div class="flex gap-2">
                        {% if min_required == 0 and max_required == 0 or min_required == 0 and max_required != 0 %}
                          <span class="flex gap-1 text-[rgb(var(--colors-text))]"><span x-html="JSON.parse(JSON.stringify(productsBundle)).filter(item => item.current_step == {{ forloop.index }}).length"></span> {{ 'products.product.item' | t }}</span>      
                        {% elsif min_required != 0 and max_required == 0 or min_required != 0 and max_required != 0 %}
                          <span :class="JSON.parse(JSON.stringify(productsBundle)).filter(item => item.current_step == {{ forloop.index }}).length >= {{ min_required }} ? '' : 'text-[rgba(var(--color-error))]'" class="flex"><span x-html="JSON.parse(JSON.stringify(productsBundle)).filter(item => item.current_step == {{ forloop.index }}).length"></span>/{{ min_required }} {% if min_required != max_required %}{{ 'products.product.item_required' | t }}{% else %}{{ 'products.product.item' | t }}{% endif %}</span>
                        {% endif %}            
                        <span class="w-2.5 {% if section.settings.summary_layout != 'vertical' %}md:hidden{% endif %} inline-block duration-500 {% if block.settings.open_by_default %} rotate-180{% endif %}" :class="open ? 'rotate-180' : 'rotate-0'">
                          {% render 'icon-alls', icon: 'icon-caret' %}
                        </span>                   
                      </div>
                    </div>
                    <div 
                      class="{% if block.settings.show_in_tab %} pl-2 pr-2 border-t border-solid border-[rgb(var(--colors-text),1)]{% endif %} overflow-hidden {% if section.settings.summary_layout != 'vertical' %} md:min-w-[248px] flex items-center {% endif %}" 
                      {% if section.settings.summary_layout == 'vertical' %}x-show="open" x-collapse x-cloak {% endif %}
                    >    
                      <div x-show="openList || open" :class="JSON.parse(JSON.stringify(productsBundle)).filter(item => item.current_step == {{ forloop.index }}).length > 0 ? 'hidden': 'flex'" class="justify-center min-h-[76px] items-center w-full h-full">{{ 'buy-your-own-bundle.no_product_chosen' | t }}</div>
                      <div class="w-full md:w-auto" x-data @resize.window="window.innerWidth < 768 ? openList = false : open = false" {% if section.settings.summary_layout != 'vertical' %}x-show="openList || open" x-collapse {% endif %} x-cloak :class="JSON.parse(JSON.stringify(productsBundle)).length > 0 ? 'block': 'hidden'">
                        <div class="bundler-content md:mt-1">
                          <div class="w-full overflow-hidden">
                            <div 
                              id="bundler-product-list-slide-{{ section.id }}-{{ block.id }}" 
                              class="w-full visible overflow-hidden flex flex-row x-splide splide scrollbar-body scrollbar-visible md:max-h-[400px]"
                              x-data-slider="{{ section.id }}"
                              x-intersect.once.margin.200px='$store.xSplide.load($el, {
                                "speed": 1000,
                                "focus": 0,
                                "omitEnd": true,
                                "pagination": false, 
                                "mediaQuery": "min",
                                "updateOnMove": "true",
                                "padding": { right: "20%" },
                                "gap": "16px",
                                {%- if settings.lang_direction contains request.locale.iso_code %} 
                                  "direction": "rtl",
                                {%- endif %}
                                "arrows": false,
                                "breakpoints": {
                                  300: {
                                    "destroy": false
                                  },
                                  768: {
                                    {%- if section.settings.summary_layout != 'vertical' and section.blocks.size > 1 -%}
                                      "destroy": true
                                    {% else %}
                                      "destroy": false
                                    {% endif %}
                                  }
                                }
                              })'
                            >
                              <div class="splide__track md:cursor-grab w-full lg:pl-0 lg:pr-0">
                                <div class="{% if request.visual_preview_mode %}md:gap-7 {% endif %}splide__list flex overflow-x-visible w-full {% if section.settings.summary_layout != 'vertical' %} md:gap-4{% endif %}">
                                <template x-for="(item,index) in Object.values(productsBundle.filter(item => item.current_step == {{ forloop.index }}))" :key="index">
                                  <div 
                                    class="splide__slide x-splide-slide flex flex-shrink-0 bundler-product-{{ section.id }} relative pt-4 gap-5"
                                    x-data="{ 
                                      item: JSON.parse(JSON.stringify(item))
                                    }"
                                  >
                                    <div class="bundler-product-image w-[70px] h-[70px] relative">
                                      <a x-bind:href="item.productUrl" class="block disable-effect w-full">
                                        <div class="relative w-full overflow-hidden float-left before:h-0 before:block before:pb-[100.0%]{% if rounded_corner %} rounded-md{% endif %}">
                                          {% # theme-check-disable ImgLazyLoading %}
                                          <img
                                            x-show="item.featured_image"
                                            class="absolute top-0 right-0 left-0 bottom-0 object-cover h-full w-full image-hover" 
                                            x-bind:src="`${ item.featured_image }`"
                                            {% if settings.enable_lazy_loading_image %}loading="lazy"{% else %}loading="eager"{% endif %}
                                            width="150"
                                            height="auto"
                                          >
                                          {% # theme-check-enable ImgLazyLoading %}
                                          <div class="bg-[#c9c9c9] absolute top-0 left-0 w-full h-full" x-show="!item.featured_image">{%- render 'icon-placeholder', icon: 'icon-product', class: 'w-full h-full' %}</div>
                                        </div>
                                      </a>
                                      <div class="bundler-button-remove cursor-pointer pl-1 pr-1 pt-1 pb-1 text-[rgba(var(--colors-text))] border border-[rgba(var(--colors-line-and-border),0.8)] bg-[rgba(var(--background-color))] rounded-full absolute rtl:-left-3 rtl:right-auto -top-3 -right-3" @click="setTimeout(() => { removeBundle($el, item.id, item.current_step) }, 0)">
                                        <span class="w-4 h-4 flex">{% render 'icon-alls', icon: 'icon-minus' %}</span>
                                      </div>
                                    </div>
                                    <div class="bundler-product-text flex-1 pr-4 lg:pr-0">
                                      <div>
                                        <a x-bind:href="item.productUrl" class="text-[rgba(var(--colors-heading))] mr-0 duration-200 transition disable-effect hover-text-link p-break-words line-clamp-3" x-text="item.product_name"></a>
                                        <p class="text-[rgba(var(--colors-text))] text-normal mt-1 opacity-70" x-show="item.title" x-text="item.title"></p>
                                        <p class="text-[rgba(var(--colors-price))] text-normal mt-1"
                                          x-show="item.price"
                                          x-text="new Intl.NumberFormat('{{ shop.locale }}', { style: 'currency', currency: '{{ cart.currency.iso_code }}' }).format(item.price / 100)"
                                        ></p>
                                      </div>
                                    </div>
                                  </div>
                                </template>
                                </div>
                              </div>
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                {% endfor %}
                {% if section.settings.summary_layout != 'vertical' and section.blocks.size > 1 %}
                    </div>
                  </div>
                </div>
                {% endif %}
              </div>
              
              <div class="mt-3.5 w-full">
                <div class="byob-total flex justify-between items-center mb-3.5 gap-2.5">
                  <span class="text-[rgb(var(--colors-text))]">{{ 'sections.cart.headings.total' | t }}</span>
                  <div class="flex flex-wrap items-center w-full justify-end">
                    <p x-show="totalDiscount == 0" class="text-[rgba(var(--colors-heading))] text-medium font-semibold" id="total-price" x-html="totalPrice"></p>
                    <div class="flex flex-wrap items-center justify-end gap-2" x-show="totalDiscount != 0">
                      <p class="text-medium font-semibold" id="total-price-discount" x-html="totalDiscount"></p>
                      <span x-show="currentDiscountReached.label && currentDiscountReached.value" class="py-1 px-2 {% if rounded_corner %}rounded-full{% endif %} bg-[rgba(var(--colors-background-secondary))] text-sm">
                        {{ 'sections.product-bundle.save' | t }} <span class="font-semibold text-[rgba(var(--discount-label-text-color))]" x-html="amountPrice"></span>
                      </span>
                    </div>
                  </div>
                </div>

                <div class="bundler-footer w-full {% if section.settings.summary_layout != 'vertical' %}flex gap-4 justify-between{% endif %}">
                  <button
                    id="button-atc-{{ section.id }}"
                    class="button-atc button button-solid block {% if section.settings.summary_layout != 'vertical' %}flex-1 {% else %}w-full button-solid {% endif %} pl-7 pr-7 pt-3 pb-3 disable-action-btn-animation disabled:cursor-not-allowed disabled:opacity-60"
                    @click="handleAddToCart($el)"
                    {% if section.settings.summary_layout != 'vertical' %}
                      :class="currentTab == {{ section.blocks.size }} ? 'md:block' : 'button-hidden'"
                    {% endif %}
                    disabled
                  >
                    {% assign button_label = 'products.product.add_all_to_cart' | t %}
                    <span :class="{ 'lg:block opacity-0 is-focus-button' : loading }">
                      <span class="flex items-center justify-center">
                        {% render 'button-label', button_label: button_label, show_button_style: 'primary' %}
                      </span>
                    </span>
                    <div class="lg:inline-block animate-spin w-4 h-4 md:w-5 md:h-5 absolute top-[calc(50%-8px)] left-[calc(50%-8px)] md:top-[calc(50%-10px)] md:left-[calc(50%-10px)]" x-show="loading" x-cloak>
                      {% render 'icon-alls', icon: 'icon-loading' %}
                    </div>
                  </button>
                </div>
              </div>
              
            </div>
          </div>
        {% endif %}
      </div>
      {% if section.settings.summary_layout != 'vertical' %}
        <div
          class="x-block-bundle-summary {% if is_rtl %}rtl {% endif %} {{ width_class_summary }} sticky {% if section.settings.summary_layout == 'vertical' %}md:relative{% endif %}{% if template.name == "product" %} bottom-14{% else %} bottom-5{% endif %} {% if section.settings.summary_layout == 'vertical' %}md:bottom-auto{% endif %} z-10"
        >
          {% style %}
            #bundler-sticky-{{ section.id }} {
              {%- if section.settings.background_color_light.alpha != 0.0 -%}
                {% if section.settings.summary_layout == 'vertical' %}
                  --colors-line-and-border: {{ section.settings.background_color_light.red }}, {{ section.settings.background_color_light.green }}, {{ section.settings.background_color_light.blue }};
                {% endif %}
                --background-color: {{ section.settings.background_color_light.red }}, {{ section.settings.background_color_light.green }}, {{ section.settings.background_color_light.blue }};
              {%- else -%}
                {% if section.settings.summary_layout == 'vertical' %}
                  --colors-line-and-border: {{ settings.colors_line_and_borders.red }}, {{ settings.colors_line_and_borders.green }}, {{ settings.colors_line_and_borders.blue }};
                {% endif %}
                --background-color: {{ settings.colors_background.red }}, {{ settings.colors_background.green }}, {{ settings.colors_background.blue }};
              {%- endif -%}
            }
            .dark #bundler-sticky-{{ section.id }} {
              {%- if section.settings.background_color_dark.alpha != 0.0 -%}
                {% if section.settings.summary_layout == 'vertical' %}
                  --colors-line-and-border: {{ section.settings.background_color_dark.red }}, {{ section.settings.background_color_dark.green }}, {{ section.settings.background_color_dark.blue }};
                {% endif %}
                --background-color: {{ section.settings.background_color_dark.red }}, {{ section.settings.background_color_dark.green }}, {{ section.settings.background_color_dark.blue }};
              {%- else -%}
                {% if section.settings.summary_layout == 'vertical' %}
                  --colors-line-and-border: {{ settings.colors_dark_line_and_borders.red }}, {{ settings.colors_dark_line_and_borders.green }}, {{ settings.colors_dark_line_and_borders.blue }};
                {% endif %}
                --background-color: {{ settings.colors_dark_background.red }}, {{ settings.colors_dark_background.green }}, {{ settings.colors_dark_background.blue }};
              {%- endif -%}
            }
            #bundler-sticky-{{ section.id }}, #bundler-sticky-{{ section.id }} *:before {
              {% if section.settings.heading_color_light.alpha != 0.0 %}
                --colors-heading: {{ section.settings.heading_color_light.red }}, {{ section.settings.heading_color_light.green }}, {{ section.settings.heading_color_light.blue }};
              {% endif %}
              {% if section.settings.text_light.alpha != 0.0 %}
                --colors-text: {{ section.settings.text_light.red }}, {{ section.settings.text_light.green }}, {{ section.settings.text_light.blue }};
              {% endif %}
              {% if section.settings.button_light.alpha != 0.0 %}
                --colors-button: {{ section.settings.button_light.red }}, {{ section.settings.button_light.green }}, {{ section.settings.button_light.blue }};
              {% endif %}
              {% if section.settings.button_text_light.alpha != 0.0 %}
                --colors-button-text: {{ section.settings.button_text_light.red }}, {{ section.settings.button_text_light.green }}, {{ section.settings.button_text_light.blue }};
              {% endif %}
              {% if section.settings.button_hover_light.alpha != 0.0 %}
                --colors-button-hover: rgb({{ section.settings.button_hover_light.red }}, {{ section.settings.button_hover_light.green }}, {{ section.settings.button_hover_light.blue }});
              {% endif %}
              {% if section.settings.button_text_hover_light.alpha != 0.0 %}
                --colors-button-text-hover: {{ section.settings.button_text_hover_light.red }}, {{ section.settings.button_text_hover_light.green }}, {{ section.settings.button_text_hover_light.blue }};
              {% endif %}
              {% if section.settings.line_border_light.alpha != 0.0 %}
                --colors-line-and-border: {{ section.settings.line_border_light.red }},{{ section.settings.line_border_light.green }},{{ section.settings.line_border_light.blue }};
              {% endif %}
              --colors-price: {{ settings.colors_price.red }}, {{ settings.colors_price.green }}, {{ settings.colors_price.blue }};
            }
            .dark #bundler-sticky-{{ section.id }}, .dark #bundler-sticky-{{ section.id }} *:before {
              {% if section.settings.heading_color_dark.alpha != 0.0 %}
                --colors-heading: {{ section.settings.heading_color_dark.red }}, {{ section.settings.heading_color_dark.green }}, {{ section.settings.heading_color_dark.blue }};
              {% else %}        
                --colors-heading: {{ settings.colors_dark_heading.red }}, {{ settings.colors_dark_heading.green }}, {{ settings.colors_dark_heading.blue }};
              {% endif %}
              {% if section.settings.text_dark.alpha != 0.0 %}
                --colors-text: {{ section.settings.text_dark.red }}, {{ section.settings.text_dark.green }}, {{ section.settings.text_dark.blue }};
              {% else %}        
                --colors-text: {{ settings.colors_dark_text.red }}, {{ settings.colors_dark_text.green }}, {{ settings.colors_dark_text.blue }};
              {% endif %}
              {% if section.settings.button_dark.alpha != 0.0 %}
                --colors-button: {{ section.settings.button_dark.red }}, {{ section.settings.button_dark.green }}, {{ section.settings.button_dark.blue }};
              {% else %}  
                --colors-button: {{ settings.colors_dark_button.red }}, {{ settings.colors_dark_button.green }}, {{ settings.colors_dark_button.blue }};
              {% endif %}
              {% if section.settings.button_text_dark.alpha != 0.0 %}
                --colors-button-text: {{ section.settings.button_text_dark.red }}, {{ section.settings.button_text_dark.green }}, {{ section.settings.button_text_dark.blue }};
              {% else %} 
                --colors-button-text: {{ settings.colors_dark_button_text.red }}, {{ settings.colors_dark_button_text.green }}, {{ settings.colors_dark_button_text.blue }}; 
              {% endif %}
              {% if section.settings.button_hover_dark.alpha != 0.0 %}
                --colors-button-hover: rgb({{ section.settings.button_hover_dark.red }}, {{ section.settings.button_hover_dark.green }}, {{ section.settings.button_hover_dark.blue }});
              {% else %}  
                --colors-button-hover: rgb({{ settings.colors_dark_button_hover.red }}, {{ settings.colors_dark_button_hover.green }}, {{ settings.colors_dark_button_hover.blue }});
              {% endif %}
              {% if section.settings.button_text_hover_dark.alpha != 0.0 %}
                --colors-button-text-hover: {{ section.settings.button_text_hover_dark.red }}, {{ section.settings.button_text_hover_dark.green }}, {{ section.settings.button_text_hover_dark.blue }};
              {% else %}  
                --colors-button-text-hover: {{ settings.colors_dark_button_text_hover.red }}, {{ settings.colors_dark_button_text_hover.green }}, {{ settings.colors_dark_button_text_hover.blue }};
              {% endif %}
              {% if section.settings.line_border_dark.alpha != 0.0 %}
                --colors-line-and-border: {{ section.settings.line_border_dark.red }},{{ section.settings.line_border_dark.green }},{{ section.settings.line_border_dark.blue }};
              {% else %}        
                --colors-line-and-border: {{ settings.colors_dark_line_and_borders.red }}, {{ settings.colors_dark_line_and_borders.green }}, {{ settings.colors_dark_line_and_borders.blue }};
              {% endif %}
              --colors-price: {{ settings.colors_dark_price.red }}, {{ settings.colors_dark_price.green }}, {{ settings.colors_dark_price.blue }};
            }
          {% endstyle %}

          <div 
            id="bundler-sticky-{{ section.id }}" 
            class="bundler-sticky {% if settings.edges_type == 'rounded_corners' %} rounded-2xl{% endif %} bg-[rgba(var(--background-color))] md:sticky top-[calc(var(--height-header)+5rem)] pl-5 pr-5 pt-5 pb-5 md:pl-7 md:pr-7 md:pt-7 md:pb-7 flex items-center flex-col border-[2px] mt-[2px] md:mt-0 border-[rgb(var(--colors-line-and-border))]"
          >
            {% if section.settings.summary_layout != 'vertical' %}
              {% style %}
                @media (max-width: 767px) {
                  .button.button-solid.open-list-btn {
                    display: none
                  }
                }
              {% endstyle %}
              <button
                class="absolute top-0 -translate-y-1/2 button button-solid open-list-btn hidden md:block flex-1 pl-7 pr-7 pt-3 pb-3 disable-action-btn-animation disabled:cursor-not-allowed disabled:opacity-60"
                @click="openList = !openList; updateSplide('{{ block.id }}', openList)"
              >
                {% assign button_label = 'templates.search.products' | t %}
                <span>
                  <span class="flex items-center justify-center">
                    {% render 'button-label', button_label: button_label, show_button_style: 'primary' %}
                    <span class="ml-1"> (<span x-html="JSON.parse(JSON.stringify(productsBundle)).length"></span>)</span>
                    <span class="w-2.5 ml-2 inline-block duration-500 {% if block.settings.open_by_default %} rotate-180{% endif %}" :class="openList ? 'rotate-180' : 'rotate-0'">
                      {% render 'icon-alls', icon: 'icon-caret' %}
                    </span>
                  </span>
                </span>
              </button>
            {% endif %}

            <div class="bundler__header w-full relative grow flex {% if section.settings.summary_layout != 'vertical' %} md:justify-center {% endif %}">
              <div class="flex w-full items-start justify-between md:justify-center">
                {%- if section.settings.bundler_heading != blank -%}
                  <h3 class="heading-bundler--{{ section.id }} title">{{ section.settings.bundler_heading | escape }}</h3>
                {%- endif -%}
                <span :class="openBundleSum ? 'hidden' : 'block'" class="md:hidden" @click="openBundleSum = true">
                  {% render 'icon-alls', icon: 'icon-plus', class: "w-5" %}
                </span>
                <span :class="openBundleSum ? 'block' : 'hidden'" class="md:hidden" @click="openBundleSum = false">
                  {% render 'icon-alls', icon: 'icon-minus', class: "w-5" %}
                </span>
              </div>
              {%- if section.settings.bundler_text != blank -%}
                <div class="rte subheading text-medium text-[rgba(var(--colors-text))] mt-1.5">{{ section.settings.bundler_text }}</div>
              {%- endif -%}
            </div>

            {% liquid
              assign text_size = settings.text_base_size | times: 0.00875
              assign text_size_mobile = settings.text_base_size | times: 0.007875

              assign available_goal_list = ''
              assign goal_count = 0
              if goal_1_threshold != blank
                assign goal_count = goal_count | plus: 1
                assign available_goal_list = available_goal_list | append: 'goal_1,'
              endif
              if goal_2_threshold != blank
                assign goal_count = goal_count | plus: 1
                assign available_goal_list = available_goal_list | append: 'goal_2,'
              endif
              if goal_3_threshold != blank
                assign goal_count = goal_count | plus: 1
                assign available_goal_list = available_goal_list | append: 'goal_3'
              endif

              assign available_goal_list = available_goal_list | split: ','
            %}
            <div x-cloak x-show="!allGoalReached && !loadPrevGoalMsg" x-text="prevGoalMsg" class="rte w-full subheading prev-goal-msg text-medium text-[rgba(var(--colors-text))] mt-2"></div>
            {% if goal_count > 0 %}
              <div class="discount-progress-bar-{{ section.id }} md:flex flex-col items-center justify-center w-full">
                {% style %}
                  {% if section.settings.goal_1_label != blank or section.settings.goal_2_label != blank or section.settings.goal_3_label != blank %}
                    {% if goal_count > 1 %}
                      .padding-text-{{ section.id }} {
                        padding-bottom: {{ text_size_mobile | times: 1.375 | plus: 0.25 }}rem;
                      }
                      @media (min-width: 768px) {
                        .padding-text-{{ section.id }} {
                          padding-bottom: {{ text_size | times: 1.375 | plus: 0.25 }}rem;
                        }
                      }  
                    {% endif %}
                  {% endif %}
                  {% if goal_count == 3 %}
                    .progress-bar-container-{{ section.id }} .discount-progress-{{ section.id }}:first-child {
                      width: 12%;
                      flex: unset
                    }
                  {% endif %}
                  .discount-progress-{{ section.id }}::after {
                    content: "";
                    position: absolute;
                    border-top-width: 4px;
                    top: -4px;
                    width: var(--progress);
                    max-width: 100%;
                    border-color: var(--color-highlight);
                    {% if rounded_corner and goal_count == 1 %}
                      border-radius: 9999px
                    {% endif %}
                  }    
                  {% if rounded_corner %}
                    .discount-progress-{{ section.id }}:first-child, .discount-progress-{{ section.id }}:first-child::after {
                      border-top-left-radius: 9999px;
                      border-bottom-left-radius: 9999px;
                    }
                    .discount-progress-{{ section.id }}.end-progress, .discount-progress-{{ section.id }}.end-progress::after {
                      border-top-right-radius: 9999px;
                      border-bottom-right-radius: 9999px;
                    }
                  {% endif %}
                  .goal-reached-{{ section.id }} {
                    background: var(--color-highlight);
                    color: rgba(var(--colors-background))
                  }
                  .progress-bar-container-{{ section.id }}{
                    {% if section.settings.line_border_light.alpha != 0.0 %}
                      --colors-line-and-border: {{ section.settings.line_border_light.red }},{{ section.settings.line_border_light.green }},{{ section.settings.line_border_light.blue }};
                    {% else %}
                      --colors-line-and-border: {{ settings.colors_line_and_borders.red }}, {{ settings.colors_line_and_borders.green }}, {{ settings.colors_line_and_borders.blue }};
                    {% endif %}
                  }
                  .dark .progress-bar-container-{{ section.id }} {
                    {% if section.settings.line_border_dark.alpha != 0.0 %}
                      --colors-line-and-border: {{ section.settings.line_border_dark.red }},{{ section.settings.line_border_dark.green }},{{ section.settings.line_border_dark.blue }};
                    {% else %}        
                      --colors-line-and-border: {{ settings.colors_dark_line_and_borders.red }}, {{ settings.colors_dark_line_and_borders.green }}, {{ settings.colors_dark_line_and_borders.blue }};
                    {% endif %}
                  }
                {% endstyle %}
                <div x-cloak x-show="allGoalReached" class="rte subheading goal-reached-msg text-medium text-[rgba(var(--colors-text))] mt-2">{{ section.settings.reach_goal_msg }}</div>
                <div x-cloak x-show="!loadDiscountBar" class="progress-bar-container-{{ section.id }} w-full md:w-3/4 flex relative items-center padding-text-{{ section.id }} pt-4">
                  {% if goal_count > 1 %}
                    {% if goal_1_threshold != '' %}
                      <div class="border-t-4 flex-1 progress-goal-1 discount-progress-{{ section.id }} relative"></div>
                      <div class="goal-destination-1 flex flex-col gap-1 relative items-center">
                        <div x-cloak {% if section.settings.caculate_discount_by == 'quantity' %}x-show="productsBundle.length < {{ goal_1_threshold }}"{% else %}x-show="productsBundle.map(item => item.price).reduce((total, item) => total + item, 0)/100 < {{ goal_1_threshold }}"{% endif %} class="w-4 h-4 rounded-full border"></div>
                        <div x-cloak {% if section.settings.caculate_discount_by == 'quantity' %}x-show="productsBundle.length >= {{ goal_1_threshold }}"{% else %}x-show="productsBundle.map(item => item.price).reduce((total, item) => total + item, 0)/100 >= {{ goal_1_threshold }}"{% endif %} class="w-4 h-4 goal-reached-{{ section.id }} rounded-full flex justify-center items-center">
                          <span class="w-2.5 h-2.5 block">
                            {% render 'icon-alls', icon: 'icon-check' %}
                          </span>
                        </div>
                        {% if section.settings.goal_1_label != blank %}
                          <div class="goal-label-1 text-ellipsis overflow-hidden max-w-[13rem] text-center absolute top-full pt-1 whitespace-nowrap">{{ section.settings.goal_1_label }}</div>
                        {% endif %}
                      </div>
                    {% endif %}
                    {% if goal_2_threshold != '' %}
                      <div class="border-t-4 flex-1 {% if goal_1_threshold == '' %}progress-goal-2{% else %}progress-pre-goal-2{% endif %} discount-progress-{{ section.id }} relative"></div>
                      <div class="goal-destination-2 flex flex-col gap-1 relative items-center">
                        <div x-cloak {% if section.settings.caculate_discount_by == 'quantity' %}x-show="productsBundle.length < {{ goal_2_threshold }}"{% else %}x-show="productsBundle.map(item => item.price).reduce((total, item) => total + item, 0)/100 < {{ goal_2_threshold }}"{% endif %} class="w-4 h-4 rounded-full border"></div>
                        <div x-cloak {% if section.settings.caculate_discount_by == 'quantity' %}x-show="productsBundle.length >= {{ goal_2_threshold }}"{% else %}x-show="productsBundle.map(item => item.price).reduce((total, item) => total + item, 0)/100 >= {{ goal_2_threshold }}"{% endif %} class="w-4 h-4 goal-reached-{{ section.id }} rounded-full flex justify-center items-center">
                          <span class="w-2.5 h-2.5 block">
                            {% render 'icon-alls', icon: 'icon-check' %}
                          </span>
                        </div>
                        {% if section.settings.goal_2_label != blank %}
                          <div class="goal-label-2 text-ellipsis overflow-hidden max-w-[13rem] text-center absolute top-full pt-1 whitespace-nowrap">{{ section.settings.goal_2_label }}</div>
                        {% endif %}
                      </div>
                    {% endif %}
                    {% if goal_3_threshold != '' %}
                      <div class="border-t-4 flex-1 progress-pre-goal-3 discount-progress-{{ section.id }} relative"></div>
                      <div class="goal-destination-3 flex flex-col gap-1 relative items-center">
                        <div x-cloak {% if section.settings.caculate_discount_by == 'quantity' %}x-show="productsBundle.length < {{ goal_3_threshold }}"{% else %}x-show="productsBundle.map(item => item.price).reduce((total, item) => total + item, 0)/100 < {{ goal_3_threshold }}"{% endif %} class="w-4 h-4 rounded-full border"></div>
                        <div x-cloak {% if section.settings.caculate_discount_by == 'quantity' %}x-show="productsBundle.length >= {{ goal_3_threshold }}"{% else %}x-show="productsBundle.map(item => item.price).reduce((total, item) => total + item, 0)/100 >= {{ goal_3_threshold }}"{% endif %} class="w-4 h-4 goal-reached-{{ section.id }} rounded-full flex justify-center items-center">
                          <span class="w-2.5 h-2.5 block">
                            {% render 'icon-alls', icon: 'icon-check' %}
                          </span>
                        </div>
                        {% if section.settings.goal_3_label != blank %}
                          <div class="goal-label-3 text-ellipsis overflow-hidden max-w-[13rem] text-center absolute top-full pt-1 whitespace-nowrap">{{ section.settings.goal_3_label }}</div>
                        {% endif %}
                      </div>
                    {% endif %}
                    <div class="border-t-4 end-progress w-[12%] discount-progress-{{ section.id }} relative"></div>
                  {% else %}
                    <div class="border-t-4 {% if rounded_corner %}rounded-full{% endif %} w-full progress-single-bar discount-progress-{{ section.id }} relative"></div>
                  {% endif %}
                </div>
              </div>
            {% endif %}
            {% style %}
              .bundler-product-list-{{ section.id }} {
                {% if section.settings.line_border_light.alpha != 0.0 %}
                  --colors-line-and-border: {{ section.settings.line_border_light.red }},{{ section.settings.line_border_light.green }},{{ section.settings.line_border_light.blue }};
                {% else %}
                  --colors-line-and-border: {{ settings.colors_line_and_borders.red }}, {{ settings.colors_line_and_borders.green }}, {{ settings.colors_line_and_borders.blue }};
                {% endif %}
              }
              .dark .bundler-product-list-{{ section.id }} {
                {% if section.settings.line_border_dark.alpha != 0.0 %}
                  --colors-line-and-border: {{ section.settings.line_border_dark.red }},{{ section.settings.line_border_dark.green }},{{ section.settings.line_border_dark.blue }};
                {% else %}        
                  --colors-line-and-border: {{ settings.colors_dark_line_and_borders.red }}, {{ settings.colors_dark_line_and_borders.green }}, {{ settings.colors_dark_line_and_borders.blue }};
                {% endif %}
              }
            {% endstyle %}
            <div :class="openBundleSum ? 'block' : 'hidden'" class="bundler-product-list bundler-product-list-{{ section.id }} md:block max-h-[180px] pr-2 md:pr-0 md:max-h-full scrollbar-body scrollbar-visible overflow-x-hidden md:h-auto mt-4 w-full">
              {% if section.settings.summary_layout != 'vertical' and section.blocks.size > 1 %}
              <div
                id="bundler-product-list-slide-horizontal-{{ section.id }}" 
                class="x-splide splide w-full visible overflow-hidden flex flex-row"
                x-data-slider="{{ section.id }}"
                x-intersect.once.margin.200px='$store.xSplide.load($el, {
                  "speed": 1000,
                  "focus": 0,
                  "omitEnd": true,
                  "pagination": false, 
                  "drag": "free",
                  "mediaQuery": "min",
                  "updateOnMove": "true",
                  "autoWidth": true,
                  "gap": "0px",
                  {%- if settings.lang_direction contains request.locale.iso_code %} 
                    "direction": "rtl",
                  {%- endif %}
                  "breakpoints": {
                    300: {
                      "destroy": true
                    },
                    768: {
                      "destroy": false
                    }
                  },
                  "arrows": false
                })'
              >
                <div class="splide__track md:cursor-grab w-full lg:pl-0 lg:pr-0">
                  <div class="{% if request.visual_preview_mode %}md:gap-7 {% endif %}splide__list flex flex-col md:flex-row overflow-x-auto md:overflow-x-visible w-full">
              {% endif %}
              {% for block in section.blocks %}
                <div id="bundler-product-list-item-step-{{ section.id }}-{{ forloop.index }}" class="bundler-product-list-item border-b pt-4 pb-4 {% if section.settings.summary_layout == 'vertical' %}md:border-b {% else %} md:border-b-0 md:pt-0 md:pb-0 splide__slide x-splide-slide {% unless forloop.last %}md:border-r{% endunless %} {% if forloop.first %} md:pr-6 {% else %} md:pl-6 md:pr-6 {% endif %}{% endif %}" 
                  x-data="{open: false }"
                  x-init="document.addEventListener(`eurus:byob:add-to-bundle-${sectionId}`, (event) => {
                    const newProduct = event.detail.newProduct;
                    if (newProduct.current_step == {{ forloop.index }}) {
                      open = true;
                    }
                  });
                  {% if section.settings.summary_layout != 'vertical' %}
                    $watch('openList', () => {
                      if (openList == false) {
                        open = false
                      }
                    });
                  {% endif %}"
                >
                  {% liquid
                    assign min_required = block.settings.min_required | default: 0
                    assign max_required = block.settings.max_required | default: 0
                  %}
                  <div class="step-block-id hidden">{{ block.id }}</div>
                  <div class="hidden" id="step-max-condition-{{ section.id }}-{{ forloop.index }}">{{ max_required }}</div>               
                  <div class="step-min-condition-{{ section.id }} hidden" x-text="JSON.parse(JSON.stringify(productsBundle)).filter(item => item.current_step == {{ forloop.index }}).length >= {{ min_required }} ? 'true' : 'false'"></div>
                  <div class="relative cursor-pointer flex justify-between md:hidden" @click="open = !open">
                    <div class="uppercase text-[rgb(var(--colors-text))]">{{ 'buy-your-own-bundle.step' | t: index: forloop.index }}</div> 
                    <div class="flex gap-2">
                      {% if min_required == 0 and max_required == 0 or min_required == 0 and max_required != 0 %}
                        <span class="flex gap-1 text-[rgb(var(--colors-text))]"><span x-html="JSON.parse(JSON.stringify(productsBundle)).filter(item => item.current_step == {{ forloop.index }}).length"></span> {{ 'products.product.item' | t }}</span>      
                      {% elsif min_required != 0 and max_required == 0 or min_required != 0 and max_required != 0 %}
                        <span :class="JSON.parse(JSON.stringify(productsBundle)).filter(item => item.current_step == {{ forloop.index }}).length >= {{ min_required }} ? '' : 'text-[rgba(var(--color-error))]'" class="flex"><span x-html="JSON.parse(JSON.stringify(productsBundle)).filter(item => item.current_step == {{ forloop.index }}).length"></span>/{{ min_required }} {% if min_required != max_required %}{{ 'products.product.item_required' | t }}{% else %}{{ 'products.product.item' | t }}{% endif %}</span>
                      {% endif %}            
                      <span class="w-2.5 {% if section.settings.summary_layout != 'vertical' %}md:hidden{% endif %} inline-block duration-500 {% if block.settings.open_by_default %} rotate-180{% endif %}" :class="open ? 'rotate-180' : 'rotate-0'">
                        {% render 'icon-alls', icon: 'icon-caret' %}
                      </span>                   
                    </div>
                  </div>
                  <div class="relative md:flex justify-between hidden">
                    <div class="uppercase text-[rgb(var(--colors-text))]">{{ 'buy-your-own-bundle.step' | t: index: forloop.index }}</div> 
                    <div class="flex gap-2">
                      {% if min_required == 0 and max_required == 0 or min_required == 0 and max_required != 0 %}
                        <span class="flex gap-1 text-[rgb(var(--colors-text))]"><span x-html="JSON.parse(JSON.stringify(productsBundle)).filter(item => item.current_step == {{ forloop.index }}).length"></span> {{ 'products.product.item' | t }}</span>      
                      {% elsif min_required != 0 and max_required == 0 or min_required != 0 and max_required != 0 %}
                        <span :class="JSON.parse(JSON.stringify(productsBundle)).filter(item => item.current_step == {{ forloop.index }}).length >= {{ min_required }} ? '' : 'text-[rgba(var(--color-error))]'" class="flex"><span x-html="JSON.parse(JSON.stringify(productsBundle)).filter(item => item.current_step == {{ forloop.index }}).length"></span>/{{ min_required }} {% if min_required != max_required %}{{ 'products.product.item_required' | t }}{% else %}{{ 'products.product.item' | t }}{% endif %}</span>
                      {% endif %}            
                      <span class="w-2.5 {% if section.settings.summary_layout != 'vertical' %}md:hidden{% endif %} inline-block duration-500 {% if block.settings.open_by_default %} rotate-180{% endif %}" :class="open ? 'rotate-180' : 'rotate-0'">
                        {% render 'icon-alls', icon: 'icon-caret' %}
                      </span>                   
                    </div>
                  </div>
                  <div 
                    class="{% if block.settings.show_in_tab %} pl-2 pr-2 border-t border-solid border-[rgb(var(--colors-text),1)]{% endif %} overflow-hidden {% if section.settings.summary_layout != 'vertical' %} md:min-w-[248px] flex items-center {% endif %}" 
                    {% if section.settings.summary_layout == 'vertical' %}x-show="open" x-collapse {% endif %}
                  >    
                    <div x-cloak x-show="openList || open" :class="JSON.parse(JSON.stringify(productsBundle)).filter(item => item.current_step == {{ forloop.index }}).length > 0 ? 'hidden': 'flex'" class="justify-center min-h-[76px] items-center w-full h-full">{{ 'buy-your-own-bundle.no_product_chosen' | t }}</div>
                    <div class="w-full md:w-auto" x-data @resize.window="window.innerWidth < 768 ? openList = false : open = false" {% if section.settings.summary_layout != 'vertical' %}x-show="openList || open" x-collapse {% endif %} x-cloak :class="JSON.parse(JSON.stringify(productsBundle)).length > 0 ? 'block': 'hidden'">
                      <div class="bundler-content md:mt-1">
                        <div class="w-full overflow-hidden">
                          <div 
                            id="bundler-product-list-slide-{{ section.id }}-{{ block.id }}" 
                            class="w-full visible overflow-hidden flex flex-row x-splide splide scrollbar-body scrollbar-visible md:max-h-[400px]"
                            x-data-slider="{{ section.id }}"
                            x-intersect.once.margin.200px='$store.xSplide.load($el, {
                              "speed": 1000,
                              "focus": 0,
                              "omitEnd": true,
                              "pagination": false, 
                              "mediaQuery": "min",
                              "updateOnMove": "true",
                              "autoWidth": true,
                              "gap": "16px",
                              {%- if settings.lang_direction contains request.locale.iso_code %} 
                                "direction": "rtl",
                              {%- endif %}
                              "arrows": false,
                              "breakpoints": {
                                300: {
                                  "destroy": false
                                },
                                768: {
                                  {%- if section.settings.summary_layout != 'vertical' and section.blocks.size > 1 -%}
                                    "destroy": true
                                  {% else %}
                                    "destroy": false
                                  {% endif %}
                                }
                              }
                            })'
                          >
                            <div class="splide__track md:cursor-grab w-full lg:pl-0 lg:pr-0">
                              <div class="{% if request.visual_preview_mode %}md:gap-7 {% endif %}splide__list flex overflow-x-visible w-full {% if section.settings.summary_layout != 'vertical' %} md:gap-4{% endif %}">
                              <template x-for="(item,index) in Object.values(productsBundle.filter(item => item.current_step == {{ forloop.index }}))" :key="index">
                                <div 
                                  class="splide__slide x-splide-slide flex flex-shrink-0 bundler-product-{{ section.id }} relative pt-4 gap-5 w-[80%] md:w-[248px]"
                                  x-data="{ 
                                    item: JSON.parse(JSON.stringify(item))
                                  }"
                                >
                                  <div class="bundler-product-image w-[70px] h-[70px] relative">
                                    <a x-bind:href="item.productUrl" class="block disable-effect w-full">
                                      <div class="relative w-full overflow-hidden float-left before:h-0 before:block before:pb-[100.0%]{% if rounded_corner %} rounded-md{% endif %}">
                                        {% # theme-check-disable ImgLazyLoading %}
                                        <img
                                          x-show="item.featured_image"
                                          class="absolute top-0 right-0 left-0 bottom-0 object-cover h-full w-full image-hover" 
                                          x-bind:src="`${ item.featured_image }`"
                                          {% if settings.enable_lazy_loading_image %}loading="lazy"{% else %}loading="eager"{% endif %}
                                          width="150"
                                          height="auto"
                                        >
                                        {% # theme-check-enable ImgLazyLoading %}
                                        <div class="bg-[#c9c9c9] absolute top-0 left-0 w-full h-full" x-show="!item.featured_image">{%- render 'icon-placeholder', icon: 'icon-product', class: 'w-full h-full' %}</div>
                                      </div>
                                    </a>
                                    <div class="bundler-button-remove cursor-pointer pl-1 pr-1 pt-1 pb-1 text-[rgba(var(--colors-text))] border border-[rgba(var(--colors-line-and-border),0.8)] bg-[rgba(var(--background-color))] rounded-full absolute rtl:-left-3 rtl:right-auto -top-3 -right-3" @click="setTimeout(() => { removeBundle($el, item.id, item.current_step) }, 0)">
                                      <span class="w-4 h-4 flex">{% render 'icon-alls', icon: 'icon-minus' %}</span>
                                    </div>
                                  </div>
                                  <div class="bundler-product-text flex-1 pr-4 lg:pr-0">
                                    <div>
                                      <a x-bind:href="item.productUrl" class="text-[rgba(var(--colors-heading))] mr-0 duration-200 transition disable-effect hover-text-link p-break-words line-clamp-3" x-text="item.product_name"></a>
                                      <p class="text-[rgba(var(--colors-text))] text-normal mt-1 opacity-70" x-show="item.title" x-text="item.title"></p>
                                      <p class="text-[rgba(var(--colors-price))] text-normal mt-1"
                                        x-show="item.price"
                                        x-text="new Intl.NumberFormat('{{ shop.locale }}', { style: 'currency', currency: '{{ cart.currency.iso_code }}' }).format(item.price / 100)"
                                      ></p>
                                    </div>
                                  </div>
                                </div>
                              </template>
                              </div>
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              {% endfor %}
              {% if section.settings.summary_layout != 'vertical' and section.blocks.size > 1 %}
                  </div>
                </div>
              </div>
              {% endif %}
            </div>
            
            <div class="mt-3.5 w-full">
              <div class="byob-total flex justify-between {% if section.settings.summary_layout != 'vertical' %}md:hidden{% endif %} mb-3.5">
                <span class="text-[rgb(var(--colors-text))]">{{ 'sections.cart.headings.total' | t }}</span>
                <div class="flex flex-wrap items-center w-full justify-end">
                  <p x-show="totalDiscount == 0" class="text-[rgba(var(--colors-heading))] text-medium font-semibold" id="total-price" x-html="totalPrice"></p>
                  <div class="flex flex-wrap items-center justify-end gap-2" x-show="totalDiscount != 0">
                    <p class="text-medium font-semibold" id="total-price-discount" x-html="totalDiscount"></p>
                    <span x-show="currentDiscountReached.label && currentDiscountReached.value" class="py-1 px-2 {% if rounded_corner %}rounded-full{% endif %} bg-[rgba(var(--colors-background-secondary))] text-sm">
                      {{ 'sections.product-bundle.save' | t }} <span class="font-semibold text-[rgba(var(--discount-label-text-color))]" x-html="amountPrice"></span>
                    </span>
                  </div>
                </div>
              </div>

              <div class="bundler-footer w-full {% if section.settings.summary_layout != 'vertical' %}flex gap-4 justify-between{% endif %}">
                {% if section.settings.summary_layout != 'vertical' %}
                  {% style %}
                    @media (max-width: 767px) {
                      .button.button-solid.next-btn, .button.button-outline.prev-btn {
                        display: none
                      }
                      .button.button-solid.button-atc.button-hidden {
                        display: block
                      }
                    }
                    @media (min-width: 768px) {
                      .button.button-solid.button-atc.button-hidden {
                        display: none
                      }
                    }
                  {% endstyle %}
                  <button
                    class="button button-outline prev-btn hidden md:block flex-1 pl-7 pr-7 pt-3 pb-3 disable-action-btn-animation disabled:cursor-not-allowed disabled:opacity-60"
                    :disabled="currentTab == 1"
                    @click="currentTab > 1 ? currentTab = currentTab - 1 : ''; scrollToStepContainer($el)"
                  >
                    {% assign button_label = 'general.global.back' | t %}
                    <span>
                      <span class="flex items-center justify-center">
                        {% render 'button-label', button_label: button_label, show_button_style: 'secondary' %}
                      </span>
                    </span>
                  </button>

                  <div class="byob-total hidden md:flex gap-2 justify-center items-center bg-[rgba(var(--colors-background-secondary))] rounded-[var(--border-radius)] w-3/5">
                    <span class="text-[rgb(var(--colors-text))]">{{ 'sections.cart.headings.total' | t }}:</span>
                    <div class="flex flex-wrap items-center w-fit justify-center">
                      <p x-show="totalDiscount == 0" class="text-[rgba(var(--colors-heading))] text-medium font-semibold" id="total-price" x-html="totalPrice"></p>
                      <div class="flex flex-wrap items-center justify-end gap-2" x-show="totalDiscount != 0">
                        <p class="text-medium font-semibold" id="total-price-discount" x-html="totalDiscount"></p>
                        <span x-show="currentDiscountReached.label && currentDiscountReached.value" class="py-1 px-2 {% if rounded_corner %}rounded-full{% endif %} bg-[rgba(var(--colors-background-secondary))] text-sm">
                          {{ 'sections.product-bundle.save' | t }} <span class="font-semibold text-[rgba(var(--discount-label-text-color))]" x-html="amountPrice"></span>
                        </span>
                      </div>
                    </div>
                  </div>

                  <button
                    class="button button-solid next-btn hidden md:block flex-1 pl-7 pr-7 pt-3 pb-3 disable-action-btn-animation disabled:cursor-not-allowed disabled:opacity-60"
                    x-show="currentTab != {{ section.blocks.size }}"
                    x-cloak
                    @click="currentTab = currentTab + 1; scrollToStepContainer($el)"
                  >
                    {% assign button_label = 'general.global.next' | t %}
                    <span>
                      <span class="flex items-center justify-center">
                        {% render 'button-label', button_label: button_label, show_button_style: 'primary' %}
                      </span>
                    </span>
                  </button>
                {% endif %}
                <button
                  id="button-atc-{{ section.id }}"
                  class="button-atc button button-solid block {% if section.settings.summary_layout != 'vertical' %}flex-1 {% else %}w-full button-solid {% endif %} pl-7 pr-7 pt-3 pb-3 disable-action-btn-animation disabled:cursor-not-allowed disabled:opacity-60"
                  @click="handleAddToCart($el)"
                  {% if section.settings.summary_layout != 'vertical' %}
                    :class="currentTab == {{ section.blocks.size }} ? 'md:block' : 'button-hidden'"
                  {% endif %}
                  disabled
                >
                  {% assign button_label = 'products.product.add_all_to_cart' | t %}
                  <span :class="{ 'lg:block opacity-0 is-focus-button' : loading }">
                    <span class="flex items-center justify-center">
                      {% render 'button-label', button_label: button_label, show_button_style: 'primary' %}
                    </span>
                  </span>
                  <div class="lg:inline-block animate-spin w-4 h-4 md:w-5 md:h-5 absolute top-[calc(50%-8px)] left-[calc(50%-8px)] md:top-[calc(50%-10px)] md:left-[calc(50%-10px)]" x-show="loading" x-cloak>
                    {% render 'icon-alls', icon: 'icon-loading' %}
                  </div>
                </button>
              </div>
            </div>
            
          </div>
        </div>
      {% endif %}
    </div>
  </div>
{%- endpaginate %}

<script src="{{ 'buy-your-own-bundle.js' | asset_url }}" defer></script>
<script src="{{ 'product-bundle.js' | asset_url }}" defer></script>  
{% schema %}
{
  "name": "t:sections.buy-your-own-bundle.name",
  "tag": "section",
  "class": "section section-byob x-section",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "aside"
    ]
  },
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.user_guide_link.section_and_blocks.buy_your_own_bundle"
    },
    {
      "type": "textarea",
      "id": "heading",
      "default": "Step-by-Step Bundle Builder",
      "label": "t:sections.all.text.heading",
      "info": "t:settings_schema.typography.settings.heading_highlight_type.info"
    },
    {
      "type": "select",
