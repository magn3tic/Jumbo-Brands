{% liquid
  assign bg_image = section.settings.background_image
  assign mobile_bg_image = section.settings.mobile_bg_image
%}

<section
  id="competition-header-{{ section.id }}"
  class="competition-header-section"
  style="
    --section-min-height: {{ section.settings.section_height }}px;
    --content-max-width: {{ section.settings.content_width }}px;
    --content-bg: {{ section.settings.content_background }};
    --heading-color: {{ section.settings.heading_color }};
    --text-color: {{ section.settings.text_color }};
    --content-radius: {{ section.settings.content_radius }}px;
    --overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="competition-header__media-wrapper">
   {% if bg_image != blank or mobile_bg_image != blank %}
  <picture>
    {% if mobile_bg_image != blank %}
      <source
        media="(max-width: 767px)"
        srcset="
          {{ mobile_bg_image | image_url: width: 375 }} 375w,
          {{ mobile_bg_image | image_url: width: 550 }} 550w,
          {{ mobile_bg_image | image_url: width: 750 }} 750w,
          {{ mobile_bg_image | image_url: width: 900 }} 900w
        "
        sizes="100vw"
      >
    {% endif %}

    {{
      bg_image
      | image_url: width: 2400
      | image_tag:
        loading: 'eager',
        widths: '768, 1200, 1600, 2000, 2400',
        sizes: '100vw',
        class: 'competition-header__bg-image',
        alt: bg_image.alt | escape
    }}
  </picture>
{% else %}
  <div class="competition-header__bg-placeholder">
    <span>Add a background image in the section settings</span>
  </div>
{% endif %}

    <div class="competition-header__overlay"></div>
<div class = "page-width page-mobile-width">
    <div class="competition-header__inner">
      <div class="competition-header__content">
        {% if section.settings.heading != blank %}
          <h1 class="h2 competition-header__heading">
            {{ section.settings.heading }}
          </h1>
        {% endif %}

        {% if section.settings.body != blank %}
          <div class="competition-header__rte rte">
            {{ section.settings.body }}
          </div>
        {% endif %}
      </div>
    </div>
</div>
  </div>
</section>
<style>
  .eurus [type='text'],
.eurus [type='email'],
[type='email'],
.eurus [type='url'],
.eurus [type='password'],
.eurus [type='number'],
.eurus [type='date'],
.eurus [type='datetime-local'],
.eurus [type='month'],
.eurus [type='search'],
.eurus [type='tel'],
.eurus [type='time'],
.eurus [type='week'],
.eurus [multiple],
.eurus textarea,
.eurus select {
    border: 1px solid #979393;
    -webkit-border-radius: 0.4rem;
}
  #competition-header-{{ section.id }} {
    position: relative;
    padding-top: var(--section-padding-top);
    padding-bottom: var(--section-padding-bottom);
  }

  #competition-header-{{ section.id }} .competition-header__media-wrapper {
    position: relative;
    min-height: var(--section-min-height);
    overflow: hidden;
    border-radius: 0;
    isolation: isolate;
  }

  #competition-header-{{ section.id }} .competition-header__bg-image,
  #competition-header-{{ section.id }} .competition-header__bg-placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  #competition-header-{{ section.id }} .competition-header__bg-image {
    object-fit: cover;
    display: block;
  }

  #competition-header-{{ section.id }} .competition-header__bg-placeholder {
    background: linear-gradient(135deg, #d30d21 0%, #ef2b2d 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    font-size: 1.4rem;
    padding: 2rem;
  }

  #competition-header-{{ section.id }} .competition-header__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, var(--overlay-opacity));
    pointer-events: none;
    z-index: 1;
  }

  #competition-header-{{ section.id }} .competition-header__inner {
    position: absolute;
    bottom:0;
   
    z-index: 2;
    padding-top: 3rem;
  }

  #competition-header-{{ section.id }} .competition-header__content {
    width: 100%;
    max-width: 590px;
    background: #F65227;
    background: linear-gradient(180deg,rgba(246, 82, 39, 1) 50%, rgba(215, 33, 33, 1) 100%);
    color: var(--text-color);
    border-radius: 40px 40px 0 0;
    padding: 2.5rem 2.5rem 2.25rem;
    box-sizing: border-box;
  }

  #competition-header-{{ section.id }} .competition-header__heading {
    margin: 0 0 1rem;
    color: var(--heading-color);
    font-size: clamp(2rem, 3.4vw, 3.25rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    font-family: Andes;
    font-weight:700
  }

  #competition-header-{{ section.id }} .competition-header__rte {
    color: var(--text-color);
    font-size: 1.2rem;
    line-height: 1.6;
    font-family: Andes
  }
  .competition-header__rte p{
    line-height:1.5rem
  }
  .text-left-with-img__rte p{
    font-size: 1.3rem
  }
  .text-left-with-img__rte li{
    font-size:1.2rem
  }

  #competition-header-{{ section.id }} .competition-header__rte > *:first-child {
    margin-top: 0;
  }

  #competition-header-{{ section.id }} .competition-header__rte > *:last-child {
    margin-bottom: 0;
  }

  #competition-header-{{ section.id }} .competition-header__rte p {
    margin: 0 0 1rem;
  }

  @media screen and (max-width: 749px) {
    #competition-header-{{ section.id }} .competition-header__inner {
      align-items: flex-end;
      padding-top: 2rem;
      padding-bottom: 2rem;
    }

    #competition-header-{{ section.id }} .competition-header__content {
      max-width: 100%;
      padding: 1.5rem;
    }

    #competition-header-{{ section.id }} .competition-header__heading {
      font-size: clamp(1.7rem, 8vw, 2.3rem);
    }
  }
@media (max-width: 900px){
        .competition-header__content{
            border-radius:0;
            max-width:100%
        }
        .page-mobile-width{
        width:100%;
        padding-right:0;
        padding-left:0
        }
        .competition-header__inner{
            padding-top:0;
            position:relative
        }
    }
    .text-left-with-img__content, .text-left-with-img__content h2, .text-left-with-img__heading, .text-left-with-img__rte{
      font-family: Andes;
      font-weight:700
    }
    .text-left-with-img__heading{
      padding-top:20px
    }
    .text-left-with-img__wrap{
      padding-bottom:1.75rem
    }
</style>

{% schema %}
{
  "name": "Competition header",
  "tag": "section",
  "class": "section section-competition-header",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Full background image"
    },
    {
    "type": "image_picker",
    "id": "mobile_bg_image",
    "label": "Mobile background image"
    },
    {
      "type": "range",
      "id": "section_height",
      "label": "Section height",
      "min": 320,
      "max": 900,
      "step": 20,
      "default": 520
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "Left content width",
      "min": 320,
      "max": 760,
      "step": 20,
      "default": 540
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Small Wins. Big Belonging."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Rich text",
      "default": "<p>Start the year with a WIN! We're celebrating resilience, gratitude, and small victories that make our community stronger.</p><p>Whether you're saving on groceries, mastering a new recipe, or helping a neighbour—we want to hear about it.</p>"
    },
    {
      "type": "color",
      "id": "content_background",
      "label": "Left block background",
      "default": "#f45a2a"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "content_radius",
      "label": "Left block corner radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 24
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Background overlay opacity",
      "min": 0,
      "max": 60,
      "step": 5,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Competition header"
    }
  ]
}
{% endschema %}