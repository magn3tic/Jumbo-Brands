{% doc %}
  @prompt
    A carousel that shows our product categories. Header of Shop By Category
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-category-carousel-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    display: block;
  }

  .ai-category-carousel__container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-category-carousel__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: {{ block.settings.heading_spacing }}px;
  }

  .ai-category-carousel__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
    font-weight: 600;
  }

  .ai-category-carousel__wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-category-carousel__track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap_between_items }}px;
    transition: transform 0.5s ease;
    padding: 10px 0;
  }

  .ai-category-carousel__item-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - ({{ block.settings.items_per_row_desktop | minus: 1 }} * {{ block.settings.gap_between_items }}px)) / {{ block.settings.items_per_row_desktop }});
    min-width: 0;
  }

  .ai-category-carousel__card-{{ ai_gen_id }} {
    position: relative;
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    display: block;
    text-decoration: none;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-category-carousel__card-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
  }

  .ai-category-carousel__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-category-carousel__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-category-carousel__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-category-carousel__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-category-carousel__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, {{ block.settings.overlay_opacity }}) 100%);
    display: flex;
    align-items: flex-end;
    padding: 20px;
  }

  .ai-category-carousel__content-{{ ai_gen_id }} {
    width: 100%;
  }

  .ai-category-carousel__category-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.category_title_size }}px;
    color: {{ block.settings.category_title_color }};
    margin: 0 0 5px;
    font-weight: 600;
  }

  .ai-category-carousel__count-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_count_size }}px;
    color: {{ block.settings.product_count_color }};
    margin: 0;
  }

  .ai-category-carousel__nav-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 15px;
    margin-top: 30px;
  }

  .ai-category-carousel__nav-button-{{ ai_gen_id }} {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background-color: {{ block.settings.nav_button_color }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease, transform 0.2s ease;
  }

  .ai-category-carousel__nav-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_button_hover_color }};
    transform: scale(1.1);
  }

  .ai-category-carousel__nav-button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-category-carousel__nav-button-{{ ai_gen_id }}:disabled:hover {
    transform: scale(1);
  }

  .ai-category-carousel__nav-button-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
    stroke: {{ block.settings.nav_icon_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-category-carousel__item-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - ({{ block.settings.items_per_row_mobile | minus: 1 }} * {{ block.settings.gap_between_items }}px)) / {{ block.settings.items_per_row_mobile }});
    }

    .ai-category-carousel__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-category-carousel__category-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.category_title_size | times: 0.85 }}px;
    }

    .ai-category-carousel__overlay-{{ ai_gen_id }} {
      padding: 15px;
    }
  }
{% endstyle %}

<category-carousel-{{ ai_gen_id }} class="ai-category-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-category-carousel__container-{{ ai_gen_id }}">
    <div class="ai-category-carousel__header-{{ ai_gen_id }}">
      <h2 class="ai-category-carousel__title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    </div>

    <div class="ai-category-carousel__wrapper-{{ ai_gen_id }}">
      <div class="ai-category-carousel__track-{{ ai_gen_id }}">
        {% for i in (1..8) %}
          {% liquid
            assign collection_key = 'collection_' | append: i
            assign collection = block.settings[collection_key]
          %}

          {% if collection != blank %}
            <div class="ai-category-carousel__item-{{ ai_gen_id }}">
              <a href="{{ collection.url }}" class="ai-category-carousel__card-{{ ai_gen_id }}">
                <div class="ai-category-carousel__image-wrapper-{{ ai_gen_id }}">
                  {% if collection.featured_image %}
                    <img
                      src="{{ collection.featured_image | image_url: width: 600 }}"
                      alt="{{ collection.title | escape }}"
                      loading="lazy"
                      width="600"
                      height="600"
                      class="ai-category-carousel__image-{{ ai_gen_id }}"
                    >
                  {% else %}
                    <div class="ai-category-carousel__placeholder-{{ ai_gen_id }}">
                      {{ 'collection-1' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                  <div class="ai-category-carousel__overlay-{{ ai_gen_id }}">
                    <div class="ai-category-carousel__content-{{ ai_gen_id }}">
                      <h3 class="ai-category-carousel__category-title-{{ ai_gen_id }}">{{ collection.title }}</h3>
                      {% if block.settings.show_product_count %}
                        <p class="ai-category-carousel__count-{{ ai_gen_id }}">{{ collection.products_count }} {% if collection.products_count == 1 %}product{% else %}products{% endif %}</p>
                      {% endif %}
                    </div>
                  </div>
                </div>
              </a>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    {% if block.settings.show_navigation %}
      <div class="ai-category-carousel__nav-{{ ai_gen_id }}">
        <button
          class="ai-category-carousel__nav-button-{{ ai_gen_id }} ai-category-carousel__prev-{{ ai_gen_id }}"
          aria-label="Previous"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
        </button>
        <button
          class="ai-category-carousel__nav-button-{{ ai_gen_id }} ai-category-carousel__next-{{ ai_gen_id }}"
          aria-label="Next"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </button>
      </div>
    {% endif %}
  </div>
</category-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class CategoryCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.itemsPerView = {{ block.settings.items_per_row_desktop }};
        this.itemsPerViewMobile = {{ block.settings.items_per_row_mobile }};
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-category-carousel__track-{{ ai_gen_id }}');
        this.items = this.querySelectorAll('.ai-category-carousel__item-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-category-carousel__prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-category-carousel__next-{{ ai_gen_id }}');

        if (!this.track || this.items.length === 0) return;

        this.updateItemsPerView();
        this.setupEventListeners();
        this.updateButtons();

        window.addEventListener('resize', () => {
          this.updateItemsPerView();
          this.updateCarousel();
        });
      }

      updateItemsPerView() {
        this.itemsPerView = window.innerWidth <= 749 ? this.itemsPerViewMobile : {{ block.settings.items_per_row_desktop }};
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.prev());
        }
        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.next());
        }
      }

      prev() {
        if (this.currentIndex > 0) {
          this.currentIndex--;
          this.updateCarousel();
        }
      }

      next() {
        const maxIndex = Math.max(0, this.items.length - this.itemsPerView);
        if (this.currentIndex < maxIndex) {
          this.currentIndex++;
          this.updateCarousel();
        }
      }

      updateCarousel() {
        const gap = {{ block.settings.gap_between_items }};
        const itemWidth = this.items[0].offsetWidth;
        const offset = -(this.currentIndex * (itemWidth + gap));
        this.track.style.transform = `translateX(${offset}px)`;
        this.updateButtons();
      }

      updateButtons() {
        const maxIndex = Math.max(0, this.items.length - this.itemsPerView);
        
        if (this.prevButton) {
          this.prevButton.disabled = this.currentIndex === 0;
        }
        if (this.nextButton) {
          this.nextButton.disabled = this.currentIndex >= maxIndex;
        }
      }
    }

    customElements.define('category-carousel-{{ ai_gen_id }}', CategoryCarousel{{ ai_gen_id }});
  })();
</script>

