<section
  id="text-left-with-img-{{ section.id }}"
  class="text-left-with-img"
  style="
    --section-bg: {{ section.settings.section_bg }};
    --heading-color: {{ section.settings.heading_color }};
    --text-color: {{ section.settings.text_color }};
   
    --card-radius: {{ section.settings.card_radius }}px;
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --image-radius: {{ section.settings.image_radius }}px;
  "
>
  <div class="page-width">
    {% if section.settings.width-size == false %}
    <div class="text-left-with-img__wrap">
      <div class="text-left-with-img__content">
        {% if section.settings.heading != blank %}
          <h2 class="text-left-with-img__heading">
            {{ section.settings.heading }}
          </h2>
        {% endif %}

        {% if section.settings.body != blank %}
          <div class="text-left-with-img__rte rte">
            {{ section.settings.body }}
          </div>
        {% endif %}
      </div>

      <div class="text-left-with-img__media">
        {% if section.settings.image != blank %}
          {{
            section.settings.image
            | image_url: width: 1600
            | image_tag:
              class: 'text-left-with-img__image',
              widths: '400, 600, 800, 1000, 1200, 1600',
              sizes: '(min-width: 990px) 40vw, 100vw',
              loading: 'lazy',
              alt: section.settings.image.alt | escape
          }}
        {% else %}
          <div class="text-left-with-img__placeholder">
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {% endif %}
      </div>
    </div>
    {% else %}
    <div class = "full-text">
       {% if section.settings.heading != blank %}
          <h2 class="text-left-with-img__heading">
            {{ section.settings.heading }}
          </h2>
        {% endif %}
        {% if section.settings.body != blank %}
          <div class="text-left-with-img__rte rte">
            {{ section.settings.body }}
          </div>
        {% endif %}
    </div>
    {% endif %}
  </div>

  <style>
    #text-left-with-img-{{ section.id }} {
      background: var(--section-bg);
      padding-top: var(--section-padding-top);
      padding-bottom: var(--section-padding-bottom);
    }

    #text-left-with-img-{{ section.id }} .text-left-with-img__wrap {
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.9fr);
      align-items: center;
      gap: 3rem;
  
      padding-top: 1.75rem;
    }

    #text-left-with-img-{{ section.id }} .text-left-with-img__content {
      max-width: 720px;
    }

    #text-left-with-img-{{ section.id }} .text-left-with-img__heading {
      margin: 0 0 1rem;
      color: var(--heading-color);
      font-size: clamp(2rem, 4vw, 3rem);
      line-height: 1.1;
      letter-spacing: -0.02em;
    }

    #text-left-with-img-{{ section.id }} .text-left-with-img__rte {
      color: var(--text-color);
      font-size: 1rem;
      line-height: 1.5;
    }

    #text-left-with-img-{{ section.id }} .text-left-with-img__rte > *:first-child {
      margin-top: 0;
    }

    #text-left-with-img-{{ section.id }} .text-left-with-img__rte > *:last-child {
      margin-bottom: 0;
    }

    #text-left-with-img-{{ section.id }} .text-left-with-img__rte p {
      margin: 0 0 0.85rem;
    }

    #text-left-with-img-{{ section.id }} .text-left-with-img__rte strong {
      font-weight: 700;
    }

    #text-left-with-img-{{ section.id }} .text-left-with-img__media {
      width: 100%;
    }

    #text-left-with-img-{{ section.id }} .text-left-with-img__image,
    #text-left-with-img-{{ section.id }} .text-left-with-img__placeholder svg {
      display: block;
      width: 100%;
      height: auto;
      border-radius: var(--image-radius);
    }

    #text-left-with-img-{{ section.id }} .text-left-with-img__placeholder {
      background: rgba(0, 0, 0, 0.04);
      border-radius: var(--image-radius);
      overflow: hidden;
    }

    @media screen and (max-width: 989px) {
      #text-left-with-img-{{ section.id }} .text-left-with-img__wrap {
        grid-template-columns: 1fr;
        gap: 2rem;
      }

      #text-left-with-img-{{ section.id }} .text-left-with-img__content {
        max-width: 100%;
      }
    }
  </style>
</section>

{% schema %}
{
  "name": "Competition Text",
  "tag": "section",
  "class": "section section-text-left-with-img",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How to Enter:"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Text",
      "default": "<p><strong>Step 1:</strong> Visit our Facebook, Instagram or TikTok page.</p><p><strong>Step 2:</strong> Look for our weekly “Small Wins” posts.</p><p><strong>Step 3:</strong> Comment your story, tip, or hack using #BostonSmallWins and tag a friend who deserves recognition.</p>"
    },
    {
        "type": "checkbox",
        "default": true,
        "id": "width-size",
        "label": "Full width"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Right image"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Background color",
      "default": "#f3ecec"
    },
   
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ef3b2d"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ef3b2d"
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Image corner radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 0
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Section corner radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 32
    }
  ],
  "presets": [
    {
      "name": "Competition Text"
    }
  ]
}
{% endschema %}